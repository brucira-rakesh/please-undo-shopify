{% comment %}
  Please Undo product card for recommendations grids.
  @param {product} product - Shopify product object
{% endcomment %}

{% liquid
  assign card_product = product
  assign variant = card_product.selected_or_first_available_variant
  assign compare_at = variant.compare_at_price
  assign price = variant.price
%}

<a href="{{ card_product.url }}" class="pu-product-card">
  <div class="pu-product-card__media">
    {% if card_product.featured_media %}
      {{
        card_product.featured_media
        | image_url: width: 600
        | image_tag: loading: 'lazy', alt: card_product.featured_media.alt | default: card_product.title, widths: '300,400,600'
      }}
    {% else %}
      <img
        src="{{ 'pu-product-mockup.png' | asset_url }}"
        alt="{{ card_product.title | escape }}"
        loading="lazy"
        width="400"
        height="400"
      >
    {% endif %}
  </div>
  <div class="pu-product-card__body">
    {% if card_product.vendor != blank %}
      <span class="pu-product-card__vendor">{{ card_product.vendor }}</span>
    {% endif %}
    <h3 class="pu-product-card__title">{{ card_product.title }}</h3>
    <div>
      <span class="pu-product-card__price">{{ price | money }}</span>
      {% if compare_at > price %}
        <span class="pu-product-card__compare">{{ compare_at | money }}</span>
      {% endif %}
    </div>
  </div>
</a>
