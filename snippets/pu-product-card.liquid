{% doc %}
  Product card for PU PDP recommendations.

  @param {product} product - Shopify product object
  @param {number} [tilt] - Card rotation index for staggered layout
{% enddoc %}

{% liquid
  assign card_product = product
  assign card_variant = card_product.selected_or_first_available_variant
  assign card_tilt = tilt | default: 1
  assign tilt_mod = card_tilt | minus: 1 | modulo: 4 | plus: 1
%}

<a
  href="{{ card_product.url }}"
  class="pu-pdp-card pu-pdp-card--tilt-{{ tilt_mod }}"
>
  <div class="pu-pdp-card__media">
    {% if card_product.featured_media %}
      {{
        card_product.featured_media
        | image_url: width: 400
        | image_tag: loading: 'lazy', alt: card_product.title, class: 'pu-pdp-card__img'
      }}
    {% else %}
      <img
        src="{{ 'pu-product-mockup.png' | asset_url }}"
        alt="{{ card_product.title | escape }}"
        class="pu-pdp-card__img"
        width="120"
        height="200"
        loading="lazy"
      >
    {% endif %}
  </div>
  <div class="pu-pdp-card__body">
    <p class="pu-pdp-card__title">{{ card_product.title }}</p>
    <p class="pu-pdp-card__price">{{ card_variant.price | money }}</p>
    <span class="pu-pdp-card__cta">View</span>
  </div>
</a>
