<section class="pu-svg-grid" data-pu-svg-grid>
  <div class="pu-svg-grid__inner">
    <div class="pu-svg-grid__stage">
      <header class="pu-svg-grid__header">
        <h2 class="pu-svg-grid__title">
          <span class="pu-svg-grid__title-line" data-pu-svg-grid-title-line>
            <span class="pu-svg-grid__title-line-inner">
              {{- section.settings.title_line_1 | default: 'we are the OFFICIAL' -}}
            </span>
          </span>
          <span class="pu-svg-grid__title-line" data-pu-svg-grid-title-line>
            <span class="pu-svg-grid__title-line-inner">
              {{- section.settings.title_line_2 | default: 'SPONSORS for those' -}}
            </span>
          </span>
          <span class="pu-svg-grid__title-line pu-svg-grid__title-line--accent" data-pu-svg-grid-title-line>
            <span class="pu-svg-grid__title-line-inner">
              {{- section.settings.title_line_3 | default: 'who never learn' -}}
            </span>
          </span>
        </h2>
      </header>
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          {% render 'pu-svg-grid-card', block: block, card_index: forloop.index0 %}
        {% endif %}
      {% endfor %}

      <div class="pu-svg-grid__center">
        <img
          class="pu-svg-grid__spark pu-svg-grid__spark--left"
          src="{{ 'pu-grid-spark-left.png' | asset_url }}"
          alt=""
          width="36"
          height="90"
          loading="lazy"
        >
        <button
          type="button"
          class="pu-svg-grid__key"
          data-pu-svg-toggle
          aria-label="Toggle illustrations"
          aria-pressed="false"
        >
          <span class="pu-svg-grid__key-cap">
            <img src="{{ 'please-undo-btn.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </span>
        </button>
        <img
          class="pu-svg-grid__spark pu-svg-grid__spark--right"
          src="{{ 'pu-grid-spark-right.png' | asset_url }}"
          alt=""
          width="36"
          height="90"
          loading="lazy"
        >
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-svg-grid {
    background: var(--pu-white);
    overflow: hidden;
  }

  .pu-svg-grid__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 16px 64px;
  }

  .pu-svg-grid__header {
    text-align: center;
    padding: clamp(48px, 6.3vw, 91px) 16px clamp(24px, 4vw, 48px);
  }

  .pu-svg-grid__title {
    margin: 0 auto;
    max-width: 900px;
    font-family: var(--pu-font-display);
    font-weight: 700;
    font-size: clamp(42px, 6.67vw, 96px);
    line-height: 0.8;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #000;
  }

  .pu-svg-grid__title-line {
    display: block;
    overflow: hidden;
  }

  .pu-svg-grid__title-line-inner {
    display: block;
    will-change: transform;
  }

  .pu-svg-grid__title-line--accent {
    color: #ff6800;
  }

  .pu-svg-grid__stage {
    position: relative;
    width: 100%;
    margin: 0 auto;
    aspect-ratio: 1100 / 620;
    min-height: 420px;
  }

  .pu-svg-grid__card {
    position: absolute;
    width: clamp(120px, 21%, 234px);
    aspect-ratio: 233 / 270;
    z-index: 1;
  }

  .pu-svg-grid__card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform: rotate(var(--card-rotate, 0deg));
    transform-origin: center center;
  }

  .pu-svg-grid__card-inner--standard {
    min-width: 235px;
    min-height: 270px;
  }

  .pu-svg-grid__card-inner--large {
    min-width: 285px;
    min-height: 330px;
  }

  .pu-svg-grid__tile {
    position: absolute;
    inset: 0;
    border-radius: 2px;
    transition: background-color 0.35s ease;
    z-index: 1;
  }

  .pu-svg-grid__card.is-swapped .pu-svg-grid__tile {
    background-color: var(--tile-color-alt, #ff6800) !important;
  }

  .pu-svg-grid__card:not(.is-swapped) .pu-svg-grid__tile {
    background-color: var(--tile-color-default, #f66400) !important;
  }

  .pu-svg-grid__figure-slot {
    position: absolute;
    pointer-events: none;
    z-index: 2;
  }

  .pu-svg-grid__figure {
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .pu-svg-grid__figure[data-pu-svg-default] {
    position: relative;
  }

  .pu-svg-grid__figure--alt {
    position: absolute;
    opacity: 0;
  }

  .pu-svg-grid__figure img {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    mix-blend-mode: darken;
  }

  .pu-svg-grid__figure-slot.pu-svg-grid__figure-top-left {
    top: -12%;
    left: -16%;
    transform: rotate(16deg);
    max-width: 200px;
  }

  .pu-svg-grid__figure-slot.pu-svg-grid__figure-bottom-left {
    bottom: 0;
    transform: rotate(-10deg);
    right: -6%;
    max-width: 240px;
  }

  .pu-svg-grid__figure-slot.pu-svg-grid__figure-top-right {
    top: -6%;
    right: -4%;
    transform: rotate(-8deg);
    max-width: 200px;
  }

  .pu-svg-grid__figure-slot.pu-svg-grid__figure-bottom-right {
    left: -12%;
    top: 10%;
    max-width: 240px;
  }

  [data-pu-svg-card].is-swapped .pu-svg-grid__figure[data-pu-svg-default],
  .pu-svg-grid__card.is-swapped .pu-svg-grid__figure[data-pu-svg-default] {
    opacity: 0;
  }

  [data-pu-svg-card].is-swapped .pu-svg-grid__figure[data-pu-svg-alt],
  .pu-svg-grid__card.is-swapped .pu-svg-grid__figure[data-pu-svg-alt] {
    opacity: 1;
  }

  .pu-svg-grid__card[data-stage-placement='top_left'] {
    top: 16%;
    left: 6%;
  }

  .pu-svg-grid__card[data-stage-placement='top_right'] {
    top: 16%;
    right: 6%;
  }

  .pu-svg-grid__card[data-stage-placement='bottom_left'] {
    left: 4%;
    bottom: 0;
  }

  .pu-svg-grid__card[data-stage-placement='bottom_right'] {
    right: 4%;
    bottom: 0;
  }

  .pu-svg-grid__center {
    position: absolute;
    left: 50%;
    top: 64%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .pu-svg-grid__spark {
    width: 32px !important;
    height: 32px !important;
    flex-shrink: 0;
    pointer-events: none;
    transition: opacity 0.35s ease, visibility 0.35s ease;
  }

  .pu-svg-grid.is-swapped .pu-svg-grid__spark {
    opacity: 0;
    visibility: hidden;
  }

  .pu-svg-grid__key {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    width: clamp(120px, 17vw, 200px);
    aspect-ratio: 242 / 199;
    padding: 0;
    border: none;
    border-radius: 10px;
    background: transparent;
    box-shadow: none;
    cursor: pointer;
    font-family: var(--pu-font-display);
    font-weight: 800;
    font-size: clamp(18px, 2.4vw, 28px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--pu-navy-text);
    -webkit-tap-highlight-color: transparent;
  }

  .pu-svg-grid__key-cap {
    display: block;
    width: 100%;
    transform: translateY(0);
    transform-origin: center bottom;
    will-change: transform;
  }

  .pu-svg-grid__key-cap img {
    display: block;
    width: 100%;
    height: auto;
  }

  .pu-svg-grid__key:hover:not(.is-active) .pu-svg-grid__key-cap {
    transition: transform 0.2s ease;
    transform: translateY(-3px);
  }

  .pu-svg-grid__key.is-pressing .pu-svg-grid__key-cap {
    transform: translateY(10px) scale(0.985);
  }

  .pu-svg-grid__key.is-active .pu-svg-grid__key-cap {
    transform: translateY(8px) scale(0.99);
  }

  .pu-svg-grid__key.is-active.is-pressing .pu-svg-grid__key-cap {
    transform: translateY(11px) scale(0.98);
  }

  @media (prefers-reduced-motion: reduce) {
    .pu-svg-grid__title-line-inner {
      will-change: auto;
    }

    .pu-svg-grid__key-cap {
      transition: none;
    }

    .pu-svg-grid__key:hover:not(.is-active) .pu-svg-grid__key-cap,
    .pu-svg-grid__key.is-pressing .pu-svg-grid__key-cap,
    .pu-svg-grid__key.is-active .pu-svg-grid__key-cap {
      transform: none;
    }
  }

  @media (max-width: 749px) {
    .pu-svg-grid {
      overflow: visible;
    }

    .pu-svg-grid__inner {
      overflow: visible;
    }

    .pu-svg-grid__stage {
      aspect-ratio: auto;
      min-height: 680px;
      max-width: 400px;
      overflow: visible;
      padding-top: 32px;
    }

    .pu-svg-grid__card {
      width: 38%;
      overflow: visible;
    }

    .pu-svg-grid__card-inner {
      overflow: visible;
    }

    .pu-svg-grid__card[data-stage-placement='top_left'] {
      left: 16px;
      top: 24%;
    }

    .pu-svg-grid__card[data-stage-placement='top_right'] {
      right: 16px;
      top: 24%;
    }

    .pu-svg-grid__card[data-stage-placement='bottom_left'] {
      left: 6px;
      bottom: 16%;
    }

    .pu-svg-grid__card[data-stage-placement='bottom_right'] {
      right: 6px;
      bottom: 16%;
    }

    .pu-svg-grid__center {
      top: 12%;
      gap: 6px;
    }

    .pu-svg-grid__spark {
      width: 18px !important;
    }

    .pu-svg-grid__card-inner--standard,
    .pu-svg-grid__card-inner--large {
      min-width: 0;
      min-height: 0;
    }

    .pu-svg-grid__card-inner--standard {
      max-width: 160px;
      max-height: 180px;
    }
    .pu-svg-grid__card-inner--large {
      max-width: 180px;
      max-height: 200px;
    }

    .pu-svg-grid__figure img {
      width: auto !important;
      max-width: 100% !important;
      height: auto !important;
    }

    .pu-svg-grid__figure-slot.pu-svg-grid__figure-top-left,
    .pu-svg-grid__figure-slot.pu-svg-grid__figure-top-right {
      max-width: 100px;
    }

    .pu-svg-grid__figure-slot.pu-svg-grid__figure-top-left {
      top: 6%;
      left: 2%;
      right: auto;
      transform: rotate(16deg);
    }

    .pu-svg-grid__figure-slot.pu-svg-grid__figure-top-right {
      top: 4%;
      right: 2%;
      left: auto;
      transform: rotate(-8deg);
    }

    .pu-svg-grid__figure-slot.pu-svg-grid__figure-bottom-left,
    .pu-svg-grid__figure-slot.pu-svg-grid__figure-bottom-right {
      max-width: 120px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU SVG Grid",
  "class": "pu-svg-grid-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title line 1",
      "default": "we are the OFFICIAL"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title line 2",
      "default": "SPONSORS for those"
    },
    {
      "type": "text",
      "id": "title_line_3",
      "label": "Title line 3 (accent)",
      "default": "who never learn"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "color",
          "id": "default_color",
          "label": "Default tile color",
          "default": "#f66400"
        },
        {
          "type": "color",
          "id": "alt_color",
          "label": "Tile color on click",
          "default": "#ff6800"
        },
        {
          "type": "select",
          "id": "tile_size",
          "label": "Tile size",
          "options": [
            { "value": "standard", "label": "Standard" },
            { "value": "large", "label": "Large" }
          ],
          "default": "standard"
        },
        {
          "type": "select",
          "id": "stage_placement",
          "label": "Position on stage",
          "options": [
            { "value": "top_left", "label": "Top left" },
            { "value": "top_right", "label": "Top right" },
            { "value": "bottom_left", "label": "Bottom left" },
            { "value": "bottom_right", "label": "Bottom right" }
          ],
          "default": "top_left"
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Tile rotation",
          "min": -20,
          "max": 20,
          "step": 1,
          "unit": "deg",
          "default": -16
        },
        {
          "type": "select",
          "id": "figure_placement",
          "label": "Illustration position on tile",
          "options": [
            { "value": "top_left", "label": "Top left" },
            { "value": "top_right", "label": "Top right" },
            { "value": "bottom_left", "label": "Bottom left" },
            { "value": "bottom_right", "label": "Bottom right" }
          ],
          "default": "top_left"
        },
        {
          "type": "image_picker",
          "id": "default_image",
          "label": "Default illustration",
          "info": "Shown before the center button is clicked."
        },
        {
          "type": "image_picker",
          "id": "alt_image",
          "label": "Alternate illustration",
          "info": "Shown after the center button is clicked."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU SVG Grid",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "default_color": "#f66400",
            "alt_color": "#fceb00",
            "tile_size": "standard",
            "stage_placement": "top_left",
            "figure_placement": "top_left",
            "rotation": -16
          }
        },
        {
          "type": "card",
          "settings": {
            "default_color": "#fceb00",
            "alt_color": "#0067ef",
            "tile_size": "standard",
            "stage_placement": "top_right",
            "figure_placement": "top_right",
            "rotation": 11
          }
        },
        {
          "type": "card",
          "settings": {
            "default_color": "#0067ef",
            "alt_color": "#00973a",
            "tile_size": "large",
            "stage_placement": "bottom_left",
            "figure_placement": "bottom_left",
            "rotation": 9
          }
        },
        {
          "type": "card",
          "settings": {
            "default_color": "#00973a",
            "alt_color": "#f66400",
            "tile_size": "large",
            "stage_placement": "bottom_right",
            "figure_placement": "bottom_right",
            "rotation": -11
          }
        }
      ]
    }
  ]
}
{% endschema %}
