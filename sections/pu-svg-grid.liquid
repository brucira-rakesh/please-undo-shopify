<section class="pu-svg-grid" data-pu-svg-grid>
  <div class="pu-svg-grid__inner">
    <header class="pu-svg-grid__header">
      <h2 class="pu-svg-grid__title">
        <span class="pu-svg-grid__title-line">
          {{- section.settings.title_line_1 | default: 'we are the OFFICIAL' -}}
        </span>
        <span class="pu-svg-grid__title-line">{{ section.settings.title_line_2 | default: 'SPONSORS for those' }}</span>
        <span class="pu-svg-grid__title-line pu-svg-grid__title-line--accent">
          {{ section.settings.title_line_3 | default: 'who never learn' }}
        </span>
      </h2>
    </header>

    <div class="pu-svg-grid__stage">
      <div
        class="pu-svg-grid__card pu-svg-grid__card--orange"
        data-pu-svg-card
        data-card-index="0"
        style="--card-rotate: -16deg;"
      >
        <div class="pu-svg-grid__card-inner pu-svg-grid__card-orange">
          <div class="pu-svg-grid__tile pu-svg-grid__tile--orange"></div>
          <div class="pu-svg-grid__figure pu-svg-grid__figure-top-left" data-pu-svg-default>
            <img src="{{ 'sponsor-top-left.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </div>
          <div class="pu-svg-grid__figure pu-svg-grid__figure--alt" data-pu-svg-alt hidden>
            <img src="{{ 'sponsor-top-left.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </div>
        </div>
      </div>

      <div
        class="pu-svg-grid__card pu-svg-grid__card--yellow"
        data-pu-svg-card
        data-card-index="1"
        style="--card-rotate: 11deg;"
      >
        <div class="pu-svg-grid__card-inner pu-svg-grid__card-yellow">
          <div class="pu-svg-grid__tile pu-svg-grid__tile--yellow "></div>
          <div class="pu-svg-grid__figure pu-svg-grid__figure-top-right" data-pu-svg-default>
            <img src="{{ 'sponsor-top-right.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </div>
          <div class="pu-svg-grid__figure pu-svg-grid__figure--alt" data-pu-svg-alt hidden>
            <img src="{{ 'sponsor-bottom-right.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </div>
        </div>
      </div>

      <div
        class="pu-svg-grid__card pu-svg-grid__card--blue"
        data-pu-svg-card
        data-card-index="2"
        style="--card-rotate: 9deg;"
      >
        <div class="pu-svg-grid__card-inner pu-svg-grid__card-blue">
          <div class="pu-svg-grid__tile pu-svg-grid__tile--blue"></div>
          <div class="pu-svg-grid__figure pu-svg-grid__figure-bottom-left" data-pu-svg-default>
            <img src="{{ 'sponsor-bottom-left.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </div>
          <div class="pu-svg-grid__figure pu-svg-grid__figure--alt" data-pu-svg-alt hidden>
            <img src="{{ 'sponsor-bottom-left.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </div>
        </div>
      </div>

      <div
        class="pu-svg-grid__card pu-svg-grid__card--green"
        data-pu-svg-card
        data-card-index="3"
        style="--card-rotate: -11deg;"
      >
        <div class="pu-svg-grid__card-inner pu-svg-grid__card-green">
          <div class="pu-svg-grid__tile pu-svg-grid__tile--green"></div>
          <div class="pu-svg-grid__figure pu-svg-grid__figure-bottom-right" data-pu-svg-default>
            <img src="{{ 'sponsor-bottom-right.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </div>
          <div class="pu-svg-grid__figure pu-svg-grid__figure--alt" data-pu-svg-alt hidden>
            <img src="{{ 'sponsor-bottom-right.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
          </div>
        </div>
      </div>

      <div class="pu-svg-grid__center">
        <img
          class="pu-svg-grid__spark pu-svg-grid__spark--left"
          src="{{ 'pu-grid-spark-left.png' | asset_url }}"
          alt=""
          width="36"
          height="90"
          loading="lazy"
        >
        <button type="button" class="pu-svg-grid__key" data-pu-svg-toggle aria-label="Toggle illustrations">
          <img src="{{ 'please-undo-btn.svg' | asset_url }}" alt="PLEASE UNDO" width="100%" height="100%">
        </button>
        <img
          class="pu-svg-grid__spark pu-svg-grid__spark--right"
          src="{{ 'pu-grid-spark-right.png' | asset_url }}"
          alt=""
          width="36"
          height="90"
          loading="lazy"
        >
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-svg-grid {
    background: var(--pu-white);
    overflow: hidden;
  }

  .pu-svg-grid__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 16px 64px;
  }

  .pu-svg-grid__header {
    text-align: center;
    padding: clamp(48px, 6.3vw, 91px) 16px clamp(24px, 4vw, 48px);
  }

  .pu-svg-grid__title {
    margin: 0 auto;
    max-width: 900px;
    font-family: var(--pu-font-display);
    font-weight: 700;
    font-size: clamp(36px, 6.67vw, 96px);
    line-height: 0.8;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #000;
  }

  .pu-svg-grid__title-line {
    display: block;
  }

  .pu-svg-grid__title-line--accent {
    color: #ff6800;
  }

  .pu-svg-grid__stage {
    position: relative;
    width: 100%;
    margin: 0 auto;
    aspect-ratio: 1100 / 620;
    min-height: 420px;
  }

  .pu-svg-grid__card {
    position: absolute;
    width: clamp(120px, 21%, 234px);
    aspect-ratio: 233 / 270;
    z-index: 1;
  }

  .pu-svg-grid__card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform: rotate(var(--card-rotate, 0deg));
    transform-origin: center center;
  }

  .pu-svg-grid__tile--orange,
  .pu-svg-grid__card-yellow {
    min-width: 235px;
    min-height: 275px;
  }

  .pu-svg-grid__card-blue,
  .pu-svg-grid__card-green {
    min-width: 285px;
    min-height: 330px;
  }

  .pu-svg-grid__tile {
    position: absolute;
    inset: 0;
    border-radius: 2px;
  }

  .pu-svg-grid__tile--orange {
    background: #f66400;
  }
  .pu-svg-grid__tile--yellow {
    background: #fceb00;
  }
  .pu-svg-grid__tile--blue {
    background: #0067ef;
  }
  .pu-svg-grid__tile--green {
    background: #00973a;
  }

  .pu-svg-grid__figure {
    position: absolute;
    /* inset: 8% 6% 4%; */
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .pu-svg-grid__figure-top-left {
    top: -39%;
    left: -45%;
    transform: rotate(16deg);
  }

  .pu-svg-grid__figure-bottom-left {
    bottom: -14%;
    transform: rotate(-10deg);
    right: -18%;
  }

  .pu-svg-grid__figure-top-right {
    top: -12%;
    right: -21%;
    transform: rotate(-8deg);
  }

  .pu-svg-grid__figure-bottom-right {
    left: -53%;
    top: -21%;
  }

  .pu-svg-grid__figure--alt {
    opacity: 0;
  }

  .pu-svg-grid__figure .pu-svg-figure {
    width: 100%;
    height: 100%;
    max-height: 100%;
  }

  [data-pu-svg-card].is-swapped .pu-svg-grid__figure[data-pu-svg-default] {
    opacity: 0;
  }

  [data-pu-svg-card].is-swapped .pu-svg-grid__figure[data-pu-svg-alt] {
    opacity: 1;
  }

  [data-pu-svg-card].is-swapped .pu-svg-grid__figure[data-pu-svg-alt][hidden] {
    display: flex !important;
  }

  .pu-svg-grid__card--orange {
    left: 10%;
    top: 2%;
  }

  .pu-svg-grid__card--yellow {
    right: 10%;
    top: 0;
  }

  .pu-svg-grid__card--blue {
    left: 2%;
    bottom: 6%;
  }

  .pu-svg-grid__card--green {
    right: 2%;
    bottom: 4%;
  }

  .pu-svg-grid__center {
    position: absolute;
    left: 50%;
    top: 54%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: clamp(8px, 2vw, 20px);
  }

  .pu-svg-grid__spark {
    width: 32px !important;
    height: 32px !important;
    flex-shrink: 0;
    pointer-events: none;
  }

  .pu-svg-grid__key {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    width: clamp(120px, 17vw, 200px);
    aspect-ratio: 242 / 199;
    padding: 12px 16px;
    border: none;
    border-radius: 10px;
    background: transparent;
    box-shadow: none;
    cursor: pointer;
    transition: transform 0.2s ease;
    font-family: var(--pu-font-display);
    font-weight: 800;
    font-size: clamp(18px, 2.4vw, 28px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--pu-navy-text);
  }

  .pu-svg-grid__key:hover {
    transform: translateY(-2px);
  }

  .pu-svg-grid__key.is-active {
    transform: translateY(2px);
    /* box-shadow: 0 2px 0 #b8b8b8, 0 4px 8px rgba(0, 0, 0, 0.1), inset 0 1px 0 #fff; */
  }

  .pu-svg-grid__key-line {
    display: block;
  }

  @media (max-width: 749px) {
    .pu-svg-grid__stage {
      aspect-ratio: auto;
      min-height: 680px;
      max-width: 400px;
    }

    .pu-svg-grid__card {
      width: 38%;
    }

    .pu-svg-grid__card--orange {
      left: 4%;
      top: 0;
    }
    .pu-svg-grid__card--yellow {
      right: 4%;
      top: 0;
    }
    .pu-svg-grid__card--blue {
      left: 4%;
      bottom: 28%;
    }
    .pu-svg-grid__card--green {
      right: 4%;
      bottom: 28%;
    }

    .pu-svg-grid__center {
      top: 62%;
      gap: 6px;
    }

    .pu-svg-grid__spark {
      width: 18px !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU SVG Grid",
  "class": "pu-svg-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title line 1",
      "default": "we are the OFFICIAL"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title line 2",
      "default": "SPONSORS for those"
    },
    {
      "type": "text",
      "id": "title_line_3",
      "label": "Title line 3 (accent)",
      "default": "who never learn"
    }
  ],
  "presets": [{ "name": "PU SVG Grid" }]
}
{% endschema %}
