<section class="pu-footer" data-pu-footer>
  <div class="pu-footer__inner">
    <div class="pu-footer__top">
      <div class="pu-footer__contact">
        <div class="pu-footer__social">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer">Instagram</a>
          {% else %}
            <span>Instagram</span>
          {% endif %}
          {% if section.settings.linkedin_url != blank %}
            <a href="{{ section.settings.linkedin_url }}" target="_blank" rel="noopener noreferrer">Linkedin</a>
          {% else %}
            <span>Linkedin</span>
          {% endif %}
        </div>
        <a href="mailto:{{ section.settings.email | default: 'hello@pleaseundo.com' }}" class="pu-footer__email">
          {{ section.settings.email | default: 'hello@pleaseundo.com' }}
        </a>
      </div>

      <div class="pu-footer__form-wrap">
        <div class="pu-footer__form-card">
          <div class="pu-footer__form-content">
            <div class="pu-footer__form-header">
              <h3 class="pu-footer__form-title">{{ section.settings.form_title | default: 'Need an Undo?' }}</h3>
              <p class="pu-footer__form-desc">
                {{
                  section.settings.form_description
                  | default: "Whether it's a question, feedback, or your latest questionable life choice, we're all ears."
                }}
              </p>
            </div>

            {% form 'customer', class: 'pu-footer__form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="pu-footer__fields">
                <input
                  type="text"
                  name="contact[first_name]"
                  class="pu-footer__input"
                  placeholder="Name"
                  aria-label="Name"
                  required
                >
                <input
                  type="email"
                  name="contact[email]"
                  class="pu-footer__input"
                  placeholder="Email"
                  aria-label="Email"
                  required
                >
              </div>
              <button type="submit" class="pu-footer__submit">SUBMIT</button>
              {% if form.posted_successfully? %}
                <p class="pu-footer__success">Thanks for reaching out!</p>
              {% endif %}
              {% if form.errors %}
                <p class="pu-footer__error">{{ form.errors | default_errors }}</p>
              {% endif %}
            {% endform %}
          </div>

          <img
            class="pu-footer__figure"
            src="{{ 'pu-stick-figure-footer.svg' | asset_url }}"
            alt=""
            width="254"
            height="269"
            loading="lazy"
          >
        </div>
      </div>
    </div>

    <div class="pu-footer__meta">
      <hr class="pu-footer__divider">
      <div class="pu-footer__legal">
        <span class="pu-footer__copyright">© {{ 'now' | date: '%Y' }} Please Undo — All rights reserved</span>
        <div class="pu-footer__legal-links">
          {% if section.settings.privacy_url != blank %}
            <a href="{{ section.settings.privacy_url }}">Privacy Policy</a>
          {% else %}
            <span>Privacy Policy</span>
          {% endif %}
          <span class="pu-footer__legal-dot" aria-hidden="true">·</span>
          {% if section.settings.terms_url != blank %}
            <a href="{{ section.settings.terms_url }}">Terms of Use</a>
          {% else %}
            <span>Terms of Use</span>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="pu-footer__brand" aria-hidden="true">
      <p class="pu-footer__brand-text">{{ section.settings.brand_text | default: 'PLEASE UNDO' }}</p>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-footer {
    background: var(--pu-navy);
    color: var(--pu-white);
    overflow: hidden;
    position: relative;
  }

  .pu-footer__inner {
    max-width: 100%;
    margin: 0 auto;
    padding: 84px 0 0;
  }

  .pu-footer__top {
    display: grid;
    grid-template-columns: 262px minmax(0, 1fr);
    gap: 40px;
    align-items: start;
    padding: 0 0 0 40px;
  }

  .pu-footer__social {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 24px;
  }

  .pu-footer__social a,
  .pu-footer__social span {
    font-family: var(--pu-font-body);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
    text-transform: uppercase;
    color: var(--pu-white);
    text-decoration: none;
  }

  .pu-footer__email {
    display: inline-block;
    font-family: var(--pu-font-body);
    font-size: 24px;
    font-weight: 500;
    line-height: normal;
    color: var(--pu-white);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-transform: lowercase;
  }

  .pu-footer__form-wrap {
    display: flex;
    justify-content: flex-end;
  }

  .pu-footer__form-card {
    position: relative;
    background: var(--pu-yellow);
    width: 100%;
    max-width: 951px;
    min-height: 370px;
    padding: 32px;
    color: var(--pu-navy);
  }

  .pu-footer__form-content {
    position: relative;
    z-index: 1;
    max-width: 458px;
  }

  .pu-footer__form-title {
    margin: 0 0 8px;
    font-family: var(--pu-font-display);
    font-size: 24px;
    font-weight: 700;
    line-height: 28px;
    color: var(--pu-navy);
  }

  .pu-footer__form-desc {
    margin: 0 0 32px;
    font-family: var(--pu-font-body);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--pu-navy);
  }

  .pu-footer__fields {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 376px;
    margin: 24px 0;
  }

  .pu-footer__input {
    width: 100%;
    height: 56px;
    padding: 0 16px;
    border: 1.5px solid #000;
    border-radius: 6px;
    background: transparent;
    font-family: var(--pu-font-body);
    font-size: 16px;
    color: var(--pu-navy);
  }

  .pu-footer__input::placeholder {
    color: rgba(0, 0, 32, 0.45);
  }

  .pu-footer__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 160px;
    height: 56px;
    padding: 10px 16px;
    border: none;
    border-bottom: 5px solid var(--pu-orange);
    border-right: 5px solid var(--pu-orange);
    border-radius: 8px;
    background: var(--pu-navy);
    color: var(--pu-white);
    font-family: var(--pu-font-display);
    font-size: 24px;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .pu-footer__submit:hover {
    transform: translate(-1px, -1px);
  }

  .pu-footer__success,
  .pu-footer__error {
    margin: 12px 0 0;
    font-size: 14px;
    color: var(--pu-navy);
  }

  .pu-footer__error {
    color: #a00;
  }

  .pu-footer__figure {
    position: absolute;
    right: 32px;
    top: 110px;
    width: 300px;
    height: auto;
    pointer-events: none;
    object-fit: contain;
  }

  .pu-footer__meta {
    margin-top: 42px;
    margin-right: 40px;
  }

  .pu-footer__divider {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    margin: 0 0 32px;
  }

  .pu-footer__legal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    max-width: 1240px;
    margin: 0 auto;
    padding-bottom: 24px;
    font-family: var(--pu-font-body);
    font-size: 14px;
    line-height: normal;
    color: rgba(255, 255, 255, 0.54);
  }

  .pu-footer__legal-links {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .pu-footer__legal-links a,
  .pu-footer__legal-links span {
    color: rgba(255, 255, 255, 0.54);
    text-decoration: none;
  }

  .pu-footer__legal-dot {
    opacity: 0.54;
  }

  .pu-footer__brand {
    --brand-size: clamp(140px, 18.9vw, 208px);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    height: calc(var(--brand-size) * 0.66);
    margin-top: 8px;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
  }

  .pu-footer__brand-text {
    margin: 0;
    padding: 0;
    font-family: var(--pu-font-display);
    font-size: var(--brand-size);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--pu-white);
    text-align: center;
    white-space: nowrap;
  }

  @media (max-width: 989px) {
    .pu-footer__inner {
      padding: 48px 24px 0;
    }

    .pu-footer__top {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .pu-footer__form-wrap {
      justify-content: stretch;
    }

    .pu-footer__form-card {
      max-width: none;
    }

    .pu-footer__figure {
      display: none;
    }

    .pu-footer__legal {
      flex-direction: column;
      align-items: flex-start;
    }

    .pu-footer__brand-text {
      white-space: normal;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Footer",
  "class": "pu-footer-section",
  "settings": [
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hello@pleaseundo.com"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "linkedin_url",
      "label": "LinkedIn URL"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form title",
      "default": "Need an Undo?"
    },
    {
      "type": "textarea",
      "id": "form_description",
      "label": "Form description",
      "default": "Whether it's a question, feedback, or your latest questionable life choice, we're all ears."
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "PLEASE UNDO"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy policy URL"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "Terms of Use URL"
    }
  ],
  "presets": [{ "name": "PU Footer" }]
}
{% endschema %}
