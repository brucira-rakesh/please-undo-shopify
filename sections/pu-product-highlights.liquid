<section class="pu-pdp-highlights pu-pdp-animate">
  <div class="pu-pdp-highlights__texture pu-texture-overlay" aria-hidden="true"></div>
  <div class="pu-pdp-highlights__inner">
    {% if section.settings.title != blank %}
      <h2 class="pu-pdp-highlights__title">{{ section.settings.title }}</h2>
    {% endif %}
    <div class="pu-pdp-highlights__grid">
      {% for block in section.blocks %}
        <div class="pu-pdp-highlight" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="pu-pdp-highlight__icon">{{ block.settings.icon }}</div>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h3 class="pu-pdp-highlight__heading">{{ block.settings.heading }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="pu-pdp-highlight__text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PU Product Highlights",
  "tag": "section",
  "class": "pu-pdp-highlights-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why you'll love it"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or character)",
          "default": "📦"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free Shipping"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "On all orders over ₹499 nationwide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Product Highlights",
      "blocks": [
        { "type": "highlight", "settings": { "icon": "📦", "heading": "Free Shipping", "text": "On all orders over ₹499 nationwide." } },
        { "type": "highlight", "settings": { "icon": "↩", "heading": "Easy Returns", "text": "30-day hassle-free returns on every order." } },
        { "type": "highlight", "settings": { "icon": "🔒", "heading": "Secure Checkout", "text": "256-bit encryption keeps your data safe." } },
        { "type": "highlight", "settings": { "icon": "✦", "heading": "Premium Materials", "text": "Thoughtfully sourced ingredients you can trust." } }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
