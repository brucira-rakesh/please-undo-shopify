{% liquid
  assign product_blocks = section.blocks | where: 'type', 'product'
  assign slider_collection = section.settings.collection
  assign products_limit = section.settings.products_limit | default: 6
  assign default_bullets = section.settings.default_bullets
  assign slide_count = 0
  assign use_collection = false

  if slider_collection != blank and slider_collection.products_count > 0
    assign use_collection = true
    assign slide_count = slider_collection.products_count
    if slide_count > products_limit
      assign slide_count = products_limit
    endif
  elsif product_blocks.size > 0
    assign slide_count = product_blocks.size
  else
    assign slide_count = 1
  endif
%}

<section class="pu-product-slider" data-pu-product-slider data-pu-product-count="{{ slide_count }}">
  <div class="pu-product-slider__texture pu-texture-overlay"></div>

  <div class="pu-product-slider__pin" data-pu-product-pin>
    <div class="pu-product-slider__hang" data-pu-hanging-title>
      <div class="pu-product-slider__swing" data-pu-hang-swing>
        <div class="pu-product-slider__rope pu-product-slider__rope--left"></div>
        <div class="pu-product-slider__rope pu-product-slider__rope--right"></div>
        <div class="pu-product-slider__sign">
          <h2 class="pu-product-slider__title">{{ section.settings.title | default: 'Pick your Undo.' }}</h2>
        </div>
      </div>
    </div>

    <div class="pu-product-slider__viewport" data-pu-product-viewport>
      <div class="pu-product-slider__track" data-pu-product-track>
        {% if use_collection %}
          {% assign slide_index = 0 %}
          {% for collection_product in slider_collection.products limit: products_limit %}
            {% liquid
              assign slide_category = 'LAPTOP NECK'
              if collection_product.metafields.custom.category != blank
                assign slide_category = collection_product.metafields.custom.category
              endif
              assign slide_bullets = default_bullets
              if slide_bullets == blank
                assign slide_bullets = '<p>Low smell</p><p>0 Stain</p><p>Daily use</p>'
              endif
            %}
            {% render 'pu-product-slider-slide',
              category: slide_category,
              title: collection_product.title,
              bullets_html: slide_bullets,
              product_image: collection_product.featured_media,
              figure_image: blank,
              shop_url: collection_product.url,
              slide_index: slide_index
            %}
            {% assign slide_index = slide_index | plus: 1 %}
          {% endfor %}
        {% elsif product_blocks.size > 0 %}
          {% for block in product_blocks %}
            {% liquid
              assign block_shop_url = block.settings.shop_now_url
              if block_shop_url == blank
                assign block_shop_url = routes.all_products_collection_url
              endif
            %}
            {% render 'pu-product-slider-slide',
              category: block.settings.subtext,
              title: block.settings.title,
              bullets_html: block.settings.bullet_points,
              product_image: block.settings.product_image,
              figure_image: block.settings.svg_icon,
              shop_url: block_shop_url,
              slide_index: forloop.index0,
              shopify_attributes: block.shopify_attributes
            %}
          {% endfor %}
        {% else %}
          {% render 'pu-product-slider-slide',
            category: 'LAPTOP NECK',
            title: 'Pain-relief Roll On',
            bullets_html: '<p>Low smell</p><p>0 Stain</p><p>Daily use</p>',
            product_image: blank,
            figure_image: blank,
            shop_url: routes.all_products_collection_url,
            slide_index: 0
          %}
        {% endif %}
      </div>
    </div>

    <div class="pu-product-slider__progress" data-pu-product-progress>
      {% for i in (1..33) %}
        <span
          class="pu-product-slider__progress-segment{% if forloop.first %} is-active{% endif %}"
          data-pu-progress-segment
        ></span>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-product-slider {
    position: relative;
    background: var(--pu-blue);
    overflow: visible;
    padding: 0 0 80px;
  }

  .pu-product-slider__hang {
    position: relative;
    z-index: 10;
    width: min(870px, 90vw);
    margin: 0 auto 56px;
    pointer-events: none;
  }

  .pu-product-slider__swing {
    position: relative;
    width: 100%;
    min-height: 220px;
    transform-origin: 50% 0;
    will-change: transform;
    backface-visibility: hidden;
    animation: pu-product-pendulum 3.2s linear infinite;
  }

  @keyframes pu-product-pendulum {
    0% {
      transform: rotate(5deg);
    }
    12.5% {
      transform: rotate(3.2deg);
    }
    25% {
      transform: rotate(0deg);
    }
    37.5% {
      transform: rotate(-3.2deg);
    }
    50% {
      transform: rotate(-2deg);
    }
    62.5% {
      transform: rotate(-3.24deg);
    }
    75% {
      transform: rotate(0deg);
    }
    87.5% {
      transform: rotate(3.2deg);
    }
    100% {
      transform: rotate(1deg);
    }
  }

  .pu-product-slider__pin {
    position: relative;
    z-index: 2;
    min-height: min(70vh, 760px);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: 8px;
  }

  .pu-product-slider__rope {
    position: absolute;
    top: -32px;
    width: 12px;
    height: 224px;
    background: var(--pu-navy);
    transform: rotate(3deg);
  }

  .pu-product-slider__rope--left {
    left: 8px;
  }
  .pu-product-slider__rope--right {
    right: 0;
    height: 182px;
    top: -35px;
    transform: rotate(2.73deg);
  }

  .pu-product-slider__sign {
    position: absolute;
    top: 80px;
    left: 50%;
    translate: -50% 0;
    rotate: 3deg;
    background: var(--pu-navy);
    padding: 24px 48px;
    min-width: min(860px, 85vw);
    text-align: center;
  }

  .pu-product-slider__title {
    margin: 0;
    font-family: var(--pu-font-display);
    font-size: clamp(48px, 8vw, 100px);
    font-weight: 700;
    color: var(--pu-white);
    text-transform: uppercase;
    letter-spacing: -2px;
    line-height: 0.9;
    opacity: 0.9;
  }

  .pu-product-slider__viewport {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .pu-product-slider__track {
    display: grid;
    grid-template-columns: 1fr;
    width: 100%;
  }

  .pu-product-slider__slide {
    grid-area: 1 / 1;
    width: 100%;
    will-change: transform;
    pointer-events: none;
  }

  .pu-product-slider__slide.is-active {
    pointer-events: auto;
  }

  .pu-product-slider__content {
    position: relative;
    display: flex;
    gap: 40px;
    margin: 0 auto;
    padding: 40px 46px 80px;
    align-items: center;
    flex: 1;
  }

  .pu-product-slider__category {
    margin: 0 0 12px;
    font-family: var(--pu-font-display);
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 2.88px;
    color: var(--pu-white);
    text-transform: uppercase;
  }

  .pu-product-slider__product-title {
    margin: 0 0 72px;
    font-family: var(--pu-font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 500;
    color: var(--pu-white);
    text-transform: uppercase;
    letter-spacing: -1.28px;
    line-height: 0.97;
  }

  .pu-product-slider__features {
    display: flex;
    gap: 9px;
    align-items: flex-start;
    margin-bottom: 72px;
  }

  .pu-product-slider__feature-nums {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pu-product-slider__feature-nums span {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 29px;
    height: 26px;
    background: #262626;
    border-radius: 65px;
    color: var(--pu-white);
    font-size: 16px;
    font-weight: 600;
  }

  .pu-product-slider__feature-text :is(p, li) {
    margin: 0 0 8px;
    font-size: 28px;
    font-weight: 500;
    color: var(--pu-white);
    line-height: 1.4;
  }

  .pu-product-slider__feature-text ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pu-product-slider__stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
    flex-shrink: 0;
  }

  .pu-product-slider__image-wrap {
    position: relative;
    width: 291px;
    height: 744px;
  }

  .pu-product-slider__product-img {
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    object-fit: contain;
  }

  .pu-product-slider__figure {
    position: absolute;
    right: -60px;
    bottom: 0;
    width: 274px;
    height: auto;
    max-width: none !important;
    object-fit: contain;
    opacity: 0.9;
  }

  .pu-product-slider__progress {
    display: flex;
    gap: 4px;
    justify-content: center;
    padding: 0 32px;
    position: relative;
    z-index: 3;
  }

  .pu-product-slider__progress-segment {
    width: 13px;
    height: 20px;
    background: rgba(217, 217, 217, 0.36);
    transition: background 0.3s ease, opacity 0.3s ease;
  }

  .pu-product-slider__progress-segment.is-active {
    background: var(--pu-white);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .pu-product-slider__swing {
      animation: none;
      transform: rotate(3deg);
    }
  }

  @media (max-width: 989px) {
    .pu-product-slider__content {
      flex-direction: column;
      padding-top: 24px;
    }
    .pu-product-slider__figure {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Product Slider",
  "class": "pu-product-slider-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Pick your Undo."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Products collection",
      "info": "Pulls slides from collection products. Manual blocks are used when empty."
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Max products from collection",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "richtext",
      "id": "default_bullets",
      "label": "Default feature bullets (collection products)",
      "default": "<p>Low smell</p><p>0 Stain</p><p>Daily use</p>"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product image"
        },
        {
          "type": "image_picker",
          "id": "svg_icon",
          "label": "SVG icon",
          "info": "Upload an SVG or PNG illustration shown beside the product."
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "LAPTOP NECK"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pain-relief Roll On"
        },
        {
          "type": "richtext",
          "id": "bullet_points",
          "label": "Bullet points",
          "default": "<p>Low smell</p><p>0 Stain</p><p>Daily use</p>"
        },
        {
          "type": "url",
          "id": "shop_now_url",
          "label": "Shop now button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Product Slider",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "subtext": "LAPTOP NECK",
            "title": "Pain-relief Roll On",
            "bullet_points": "<p>Low smell</p><p>0 Stain</p><p>Daily use</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
