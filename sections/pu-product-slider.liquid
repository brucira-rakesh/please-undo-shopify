{% liquid
  assign product_blocks = section.blocks | where: 'type', 'product'
  assign feature_card_blocks = section.blocks | where: 'type', 'feature_card'
  assign slider_collection = section.settings.collection
  assign products_limit = section.settings.products_limit | default: 6
  assign default_bullets = section.settings.default_bullets
  assign slide_count = 0
  assign use_collection = false

  if product_blocks.size > 0
    assign slide_count = product_blocks.size
  elsif slider_collection != blank and slider_collection.products_count > 0
    assign use_collection = true
    assign slide_count = slider_collection.products_count
    if slide_count > products_limit
      assign slide_count = products_limit
    endif
  else
    assign slide_count = 1
  endif
%}

<section
  class="pu-product-slider"
  data-pu-product-slider
  data-pu-product-count="{{ slide_count }}"
  data-slide-scroll-vh="{{ section.settings.slide_scroll_vh | default: 60 }}"
  data-pin-hold-scroll-vh="{{ section.settings.pin_hold_scroll_vh | default: 45 }}"
  data-slide-last-transition-scroll-vh="{{ section.settings.slide_last_transition_scroll_vh | default: 80 }}"
>
  <div class="pu-product-slider__texture pu-texture-overlay" aria-hidden="true"></div>

  <div class="pu-product-slider__hang" data-pu-hanging-title>
    <div class="pu-product-slider__swing is-css-swing">
      {% comment %} data-pu-hang-swing {% endcomment %}
      <div class="pu-product-slider__rope pu-product-slider__rope--left"></div>
      <div class="pu-product-slider__rope pu-product-slider__rope--right"></div>
      <div class="pu-product-slider__sign">
        <h2 class="pu-product-slider__title">{{ section.settings.title | default: 'Pick your Undo.' }}</h2>
      </div>
    </div>
  </div>

  <div class="pu-product-slider__pin" data-pu-product-pin>
    <div class="pu-product-slider__texture pu-texture-overlay" aria-hidden="true"></div>

    <div class="pu-product-slider__viewport" data-pu-product-viewport>
      <div class="pu-product-slider__track" data-pu-product-track>
        {% if product_blocks.size > 0 %}
          {% for block in product_blocks %}
            {% liquid
              assign block_shop_url = block.settings.shop_now_url
              if block_shop_url == blank
                assign block_shop_url = routes.all_products_collection_url
              endif
            %}
            {% render 'pu-product-slider-slide',
              category: block.settings.subtext,
              title: block.settings.title,
              bullets_html: block.settings.bullet_points,
              product_image: block.settings.product_image,
              figure_image: block.settings.svg_icon,
              figure_right: block.settings.figure_right,
              shop_url: block_shop_url,
              slide_index: forloop.index0,
              shopify_attributes: block.shopify_attributes
            %}
          {% endfor %}
        {% elsif use_collection %}
          {% assign slide_index = 0 %}
          {% for collection_product in slider_collection.products limit: products_limit %}
            {% liquid
              assign slide_category = 'LAPTOP NECK'
              if collection_product.metafields.custom.category != blank
                assign slide_category = collection_product.metafields.custom.category
              endif
              assign slide_bullets = default_bullets
              if slide_bullets == blank
                assign slide_bullets = '<p>Low smell</p><p>0 Stain</p><p>Daily use</p>'
              endif
            %}
            {% render 'pu-product-slider-slide',
              category: slide_category,
              title: collection_product.title,
              bullets_html: slide_bullets,
              product_image: collection_product.featured_media,
              figure_image: blank,
              shop_url: collection_product.url,
              slide_index: slide_index
            %}
            {% assign slide_index = slide_index | plus: 1 %}
          {% endfor %}
        {% else %}
          {% render 'pu-product-slider-slide',
            category: 'LAPTOP NECK',
            title: 'Pain-relief Roll On',
            bullets_html: '<p>Low smell</p><p>0 Stain</p><p>Daily use</p>',
            product_image: blank,
            figure_image: blank,
            shop_url: routes.all_products_collection_url,
            slide_index: 0
          %}
        {% endif %}
      </div>
    </div>

    {% if slide_count > 1 %}
      <div class="pu-product-slider__progress" data-pu-product-progress>
        {% for i in (1..slide_count) %}
          <span
            class="pu-product-slider__progress-segment{% if forloop.first %} is-active{% endif %}"
            data-pu-progress-segment
          ></span>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="pu-features-modal" data-pu-features-modal aria-hidden="true">
    <div class="pu-features-modal__backdrop" data-pu-features-backdrop></div>
    <div
      class="pu-features-modal__panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="pu-features-modal-title-{{ section.id }}"
    >
      <button
        type="button"
        class="pu-features-modal__close"
        data-pu-features-close
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 28 28" fill="none">
          <path d="M26 2L2 26M2 2L26 26" stroke="#060623" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      {% comment %}
        <div class="pu-features-modal__sign">
          <h3 id="pu-features-modal-title-{{ section.id }}" class="pu-features-modal__title">
            {{ section.settings.features_modal_title | default: 'Pick your Undo.' }}
          </h3>
        </div>
      {% endcomment %}

      <div class="pu-features-modal__stage">
        <img
          class="pu-features-modal__bottle"
          src="{{ 'image.png' | asset_url }}"
          alt=""
          width="200"
          height="520"
          loading="lazy"
        >

        <div class="pu-features-modal__grid">
          {% if feature_card_blocks.size > 0 %}
            {% for block in feature_card_blocks %}
              {% render 'pu-product-feature-card',
                icon: block.settings.icon,
                label: block.settings.label,
                tag_color: block.settings.tag_color,
                shopify_attributes: block.shopify_attributes
              %}
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-product-slider {
    position: relative;
    background: var(--pu-blue);
    overflow: visible;
    padding-top: 8px;
  }

  .pu-product-slider > .pu-product-slider__texture {
    z-index: 0;
  }

  .pu-product-slider__texture {
    background-size: 2400px auto;
    background-position: top center;
    background-repeat: no-repeat;
  }

  .pu-product-slider__hang {
    position: relative;
    z-index: 2;
    width: min(870px, 90vw);
    margin: 0 auto 56px;
    pointer-events: none;
    transform-origin: top center;
  }

  .pu-product-slider__pin {
    position: relative;
    z-index: 1;
    min-height: min(56vh, 620px);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 0 0 80px;
    background: var(--pu-blue);
    overflow-x: clip;
  }

  .pu-product-slider__pin > .pu-product-slider__texture {
    z-index: 0;
  }

  .pu-product-slider__viewport,
  .pu-product-slider__progress {
    position: relative;
    z-index: 1;
  }

  .pu-product-slider__swing {
    position: relative;
    width: 100%;
    min-height: 220px;
    transform-origin: 50% 0;
    will-change: transform;
    backface-visibility: hidden;
  }

  @keyframes pu-product-pendulum {
    0%,
    100% {
      transform: rotate(-4.5deg);
    }
    50% {
      transform: rotate(4.5deg);
    }
  }

  .pu-product-slider__swing.is-css-swing {
    animation: pu-product-pendulum 4.8s ease-in-out infinite;
  }

  .pu-product-slider__rope {
    position: absolute;
    top: -56px;
    width: 12px;
    height: 224px;
    background: var(--pu-navy);
    transform: rotate(3deg);
  }

  .pu-product-slider__rope--left {
    left: 12px;
    height: 182px;
  }
  .pu-product-slider__rope--right {
    right: 0;
    height: 182px;
    top: -48px;
    transform: rotate(2.73deg);
  }

  .pu-product-slider__sign {
    position: absolute;
    top: 80px;
    left: 50%;
    translate: -50% 0;
    rotate: 3deg;
    background: var(--pu-navy);
    padding: 24px 48px;
    min-width: min(860px, 85vw);
    text-align: center;
  }

  .pu-product-slider__title {
    margin: 0;
    font-family: var(--pu-font-display);
    font-size: clamp(48px, 8vw, 100px);
    font-weight: 700;
    color: var(--pu-white);
    text-transform: uppercase;
    letter-spacing: -2px;
    line-height: 0.9;
    opacity: 0.9;
  }

  .pu-product-slider__viewport {
    position: relative;
    width: 100%;
    overflow: hidden;
    overflow-x: clip;
    touch-action: pan-y;
    isolation: isolate;
    container-type: inline-size;
    container-name: product-slider;
  }

  .pu-product-slider__track {
    display: flex;
    flex-wrap: nowrap;
    width: max-content;
    min-height: 1px;
    will-change: transform;
  }

  .pu-product-slider__slide {
    flex: 0 0 100cqw;
    width: 100cqw;
    min-width: 100cqw;
    max-width: 100cqw;
    box-sizing: border-box;
    overflow: hidden;
    pointer-events: none;
  }

  .pu-product-slider__slide.is-active {
    pointer-events: auto;
  }

  .pu-product-slider__content {
    position: relative;
    display: flex;
    gap: 40px;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    padding: 40px 120px 80px;
    align-items: center;
    flex: 1;
    box-sizing: border-box;
  }

  .pu-product-slider__content .pu-product-slider__info,
  .pu-product-slider__content .pu-product-slider__stage {
    min-width: 33.33%;
  }

  .pu-product-slider__info .pu-btn {
    min-width: 440px;
    display: block;
    max-width: 440px;
    text-align: center;
  }

  .pu-product-slider__category {
    margin: 0 0 12px;
    font-family: var(--pu-font-display);
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 2.88px;
    color: var(--pu-white);
    text-transform: uppercase;
  }

  .pu-product-slider__product-title {
    margin: 0 0 72px;
    font-family: var(--pu-font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 500;
    color: var(--pu-white);
    text-transform: uppercase;
    letter-spacing: -1.28px;
    line-height: 0.97;
    transition: margin-bottom 0.45s ease;
  }

  .pu-product-slider.is-pinned .pu-product-slider__product-title {
    margin-bottom: 16px;
  }

  .pu-product-slider__features {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 56px;
  }

  .pu-product-slider__feature-row {
    display: flex;
    gap: 9px;
    align-items: center;
  }

  .pu-product-slider__feature-num {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 29px;
    height: 26px;
    background: #262626;
    border-radius: 65px;
    color: var(--pu-white);
    font-size: 16px;
    font-weight: 600;
    line-height: 1;
  }

  .pu-product-slider__feature-label {
    font-size: 28px;
    font-weight: 500;
    color: var(--pu-white);
    line-height: 1.4;
  }

  .pu-product-slider__stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
    flex-shrink: 0;
  }

  .pu-product-slider__image-wrap {
    position: relative;
    min-width: 160px;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .pu-product-slider__product-img {
    position: relative;
    z-index: 2;
    object-fit: contain;
    width: 100%;
    height: 744px;
    aspect-ratio: 88 / 225;
  }

  .pu-product-slider__figure {
    position: absolute;
    right: var(--figure-right, -60px);
    bottom: 0;
    z-index: 2;
    width: 320px;
    height: auto;
    max-width: none !important;
    object-fit: contain;
    opacity: 0.9;
    pointer-events: none;
  }

  .pu-product-slider__progress {
    display: flex;
    gap: 4px;
    justify-content: center;
    padding: 0 32px;
    position: relative;
    z-index: 3;
  }

  .pu-product-slider__progress-segment {
    width: 13px;
    height: 20px;
    background: rgba(217, 217, 217, 0.36);
    transition: background 0.3s ease, opacity 0.3s ease;
  }

  .pu-product-slider__progress-segment.is-active {
    background: var(--pu-white);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .pu-product-slider__swing,
    .pu-product-slider__swing.is-css-swing {
      animation: none;
      transform: rotate(3deg);
    }
  }

  @media (max-width: 989px) {
    .pu-product-slider__content {
      flex-direction: column;
      padding-top: 24px;
    }

    .pu-product-slider__figure {
      width: min(220px, 58vw);
    }
  }

  @media (max-width: 749px) {
    .pu-product-slider {
      overflow-x: clip;
    }

    .pu-product-slider__pin {
      min-height: auto;
      padding-bottom: 48px;
    }

    .pu-product-slider__hang {
      width: calc(100% - 32px);
      margin-bottom: 24px;
    }

    .pu-product-slider__sign {
      position: relative;
      top: 64px;
      left: auto;
      translate: none;
      min-width: 0;
      padding: 16px 20px;
    }

    .pu-product-slider__rope--left {
      left: 3px;
    }

    .pu-product-slider__content {
      padding: 16px 16px 40px;
      gap: 24px;
    }

    .pu-product-slider__content .pu-product-slider__info,
    .pu-product-slider__content .pu-product-slider__stage {
      min-width: 0;
      width: 100%;
    }

    .pu-product-slider__content .pu-product-slider__info {
      order: 1;
    }

    .pu-product-slider__content .pu-product-slider__stage {
      order: 0;
    }

    .pu-product-slider__product-title {
      margin-bottom: 24px;
      font-size: clamp(28px, 8vw, 40px);
    }

    .pu-product-slider.is-pinned .pu-product-slider__product-title {
      margin-bottom: 16px;
    }

    .pu-product-slider__features {
      margin-bottom: 32px;
    }

    .pu-product-slider__feature-label {
      font-size: clamp(18px, 4.5vw, 22px);
    }

    .pu-product-slider__category {
      font-size: clamp(16px, 4vw, 20px);
    }

    .pu-product-slider__stage {
      min-height: auto;
    }

    .pu-product-slider__image-wrap {
      width: min(200px, 70vw);
      height: auto;
      aspect-ratio: 1 / 2;
      margin: 0 auto;
    }

    .pu-product-slider__figure {
      width: min(140px, 42vw);
    }

    .pu-product-slider__rope--right {
      right: -3px;
    }

    .pu-product-slider__swing {
      max-height: 100px;
    }

    .pu-product-slider__product-img {
      height: 420px;
    }

    .pu-product-slider__info .pu-btn {
      max-width: 100%;
      min-width: 100%;
    }
  }

  /* ─── Features popup ─── */
  .pu-features-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease;
  }

  .pu-features-modal.is-open {
    opacity: 1;
    visibility: visible;
  }

  .pu-features-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 32, 0.78);
  }

  .pu-features-modal__panel {
    position: relative;
    z-index: 1;
    width: min(1080px, 94vw);
    height: 100%;
    max-height: 85vh;
    overflow-y: auto;
    border-radius: 24px;
    padding: 64px 40px 40px;
    transform: scale(0.96);
    transition: transform 0.25s ease;
  }

  .pu-features-modal.is-open .pu-features-modal__panel {
    transform: scale(1);
  }

  .pu-features-modal__close {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: var(--pu-white);
    color: var(--pu-navy);
    cursor: pointer;
  }

  .pu-features-modal__close svg {
    width: 16px;
    height: 16px;
  }

  .pu-features-modal__sign {
    display: inline-block;
    background: var(--pu-navy);
    padding: 16px 32px;
    margin: 0 0 32px;
    rotate: -3deg;
  }

  .pu-features-modal__title {
    margin: 0;
    font-family: var(--pu-font-display);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    color: var(--pu-gray);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }

  .pu-features-modal__stage {
    position: relative;
    height: 100%;
  }

  .pu-features-modal__bottle {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    object-fit: cover;
    pointer-events: none;
  }

  .pu-features-modal__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  .pu-features-card {
    display: flex;
    flex-direction: column;
    background: #f1eff4;
    border-radius: 10px;
    overflow: hidden;
  }

  .pu-features-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-height: 110px;
    padding: 20px;
  }

  .pu-features-card__icon-img {
    width: 100%;
    max-width: 72px !important;
    height: auto !important;
    object-fit: contain;
  }

  .pu-features-card__tag {
    padding: 10px 8px;
    text-align: center;
    font-family: var(--pu-font-body);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--pu-white);
  }

  .pu-features-card__tag--purple {
    background: #6e36b9;
  }

  .pu-features-card__tag--green {
    background: var(--pu-green, #00973a);
  }

  .pu-features-card__tag--navy {
    background: var(--pu-navy);
  }

  .pu-features-card__tag--orange {
    background: var(--pu-orange);
  }

  @media (max-width: 989px) {
    .pu-features-modal__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 749px) {
    .pu-features-modal__panel {
      padding: 56px 20px 24px;
      border-radius: 16px;
    }

    .pu-features-modal__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .pu-features-modal__bottle {
      width: 90px;
    }

    .pu-features-modal__sign {
      padding: 12px 20px;
      margin-bottom: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pu-features-modal,
    .pu-features-modal__panel {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Product Slider",
  "class": "pu-product-slider-section",
  "max_blocks": 24,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Pick your Undo."
    },
    {
      "type": "text",
      "id": "features_modal_title",
      "label": "Features popup title",
      "default": "Pick your Undo."
    },
    {
      "type": "range",
      "id": "slide_scroll_vh",
      "label": "Scroll distance per product",
      "min": 50,
      "max": 180,
      "step": 5,
      "unit": "vh",
      "default": 60,
      "info": "Scroll distance for each product transition except the final one."
    },
    {
      "type": "range",
      "id": "slide_last_transition_scroll_vh",
      "label": "Last product transition scroll",
      "min": 50,
      "max": 180,
      "step": 5,
      "unit": "vh",
      "default": 80,
      "info": "Extra scroll for the transition into the final product."
    },
    {
      "type": "range",
      "id": "pin_hold_scroll_vh",
      "label": "Pin hold scroll (first & last product)",
      "min": 40,
      "max": 160,
      "step": 5,
      "unit": "vh",
      "default": 45,
      "info": "Extra scroll on the first product before advancing, and on the last product before unpinning."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Products collection",
      "info": "Used only when no Product blocks are added below."
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Max products from collection",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "richtext",
      "id": "default_bullets",
      "label": "Default feature bullets (collection products)",
      "default": "<p>Low smell</p><p>0 Stain</p><p>Daily use</p>"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product image"
        },
        {
          "type": "image_picker",
          "id": "svg_icon",
          "label": "SVG icon",
          "info": "Upload an SVG or PNG illustration shown beside the product."
        },
        {
          "type": "range",
          "id": "figure_right",
          "label": "Icon position right",
          "info": "Horizontal offset from the right edge of the product image. Use negative values to overlap the bottle.",
          "min": -100,
          "max": 50,
          "step": 5,
          "unit": "px",
          "default": -60
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "LAPTOP NECK"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pain-relief Roll On"
        },
        {
          "type": "richtext",
          "id": "bullet_points",
          "label": "Bullet points",
          "default": "<p>Low smell</p><p>0 Stain</p><p>Daily use</p>"
        },
        {
          "type": "url",
          "id": "shop_now_url",
          "label": "Shop now button link"
        }
      ]
    },
    {
      "type": "feature_card",
      "name": "Feature card (popup)",
