{% liquid
  assign patch_blocks = section.blocks | where: 'type', 'patch'
  assign art_w = 1146
  assign art_h = 599.7
%}

<section class="pu-hero" data-pu-hero>
  <div class="pu-hero__texture pu-texture-overlay"></div>

  <div class="pu-hero__inner">
    <div
      class="pu-hero__art"
      style="--art-w: {{ art_w }}; --art-h: {{ art_h }};"
    >
      <h1 class="pu-hero__title pu-hero__title--dark">{{ section.settings.title_line_1 | default: 'SILLY THING' }}</h1>
      <h1 class="pu-hero__title pu-hero__title--yellow">{{ section.settings.title_line_2 | default: 'PLEASE UNDO' }}</h1>

      <div class="pu-hero__patches">
        {% if patch_blocks.size > 0 %}
          {% for block in patch_blocks %}
            {% render 'pu-hero-patch', block: block %}
          {% endfor %}
        {% else %}
          <div class="pu-hero__patch pu-hero__patch--for-every">
            <div class="pu-sticker pu-hero__patch-inner"><span>For every</span></div>
          </div>
          <div class="pu-hero__patch pu-hero__patch--theres-a">
            <div class="pu-sticker pu-hero__patch-inner"><span>There's a</span></div>
          </div>
          <div class="pu-hero__patch pu-hero__patch--you-do">
            <div class="pu-sticker pu-hero__patch-inner"><span>you do</span></div>
          </div>
        {% endif %}
      </div>

      <div class="pu-hero__fig pu-hero__fig--on-s" aria-hidden="true">
        <img src="{{ 'pu-hero-figure-sprite.png' | asset_url }}" alt="" width="1462" height="762" loading="eager">
      </div>

      <div class="pu-hero__fig pu-hero__fig--on-g" aria-hidden="true">
        <img src="{{ 'pu-hero-figure-sprite.png' | asset_url }}" alt="" width="1462" height="762" loading="eager">
      </div>

      <div class="pu-hero__fig pu-hero__fig--sitting" aria-hidden="true">
        <img src="{{ 'pu-hero-figure-sprite.png' | asset_url }}" alt="" width="1462" height="762" loading="eager">
      </div>

      <div class="pu-hero__fig pu-hero__fig--runner" aria-hidden="true">
        <img src="{{ 'pu-hero-runner.png' | asset_url }}" alt="" width="104" height="108" loading="eager">
      </div>

      <div class="pu-hero__product-wrap" aria-hidden="true">
        {% if section.settings.product_image != blank %}
          {{
            section.settings.product_image
            | image_url: width: 120
            | image_tag: class: 'pu-hero__product', alt: 'Please Undo product', loading: 'eager', width: 52, height: 131
          }}
        {% else %}
          <img
            class="pu-hero__product"
            src="{{ 'pu-hero-bottle.png' | asset_url }}"
            alt="Please Undo product"
            width="52"
            height="131"
            loading="eager"
          >
        {% endif %}
      </div>
    </div>

    {% if section.settings.button_label != blank %}
      <a
        href="{{ section.settings.button_link | default: routes.all_products_collection_url }}"
        class="pu-btn pu-btn--yellow pu-hero__cta"
      >
        {{ section.settings.button_label }}
      </a>
    {% endif %}

    <div class="pu-hero__tickers">
      <div class="pu-hero__ticker pu-hero__ticker--white">
        <div class="pu-ticker">
          <div class="pu-ticker__track">
            {% for i in (1..8) %}
              <span>{{ section.settings.ticker_1_text | default: "it's human to mess up" }}</span>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="pu-hero__ticker pu-hero__ticker--orange">
        <div class="pu-ticker pu-ticker--reverse">
          <div class="pu-ticker__track">
            {% for i in (1..8) %}
              <span>{{ section.settings.ticker_2_text | default: 'your right to a quick reset' }}</span>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-hero {
    --hero-frame-h: 851;
    position: relative;
    background: #006eff;
    overflow: hidden;
  }

  .pu-hero-section {
    position: relative;
    z-index: 3;
  }

  .pu-hero__inner {
    --scale: min(1, (100vw - 64px) / 1146);
    position: relative;
    padding-top: calc(40px + var(--header-group-height, 88px));
    min-height: calc(885 * var(--scale) * 1px);
  }

  .pu-hero__art {
    --uw: calc(1146 * var(--scale) * 1px);
    --uh: calc(599.7 * var(--scale) * 1px);
    --px: calc(1px * var(--scale));
    position: relative;
    width: var(--uw);
    height: var(--uh);
    margin: 0 auto;
  }

  .pu-hero__title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: calc(1004.541 / var(--art-w) * 100%);
    margin: 0;
    font-family: var(--pu-font-display);
    font-weight: 800;
    font-size: calc(202.163 * var(--px));
    text-transform: uppercase;
    text-align: center;
    white-space: nowrap;
  }

  /* Figma 847:184 */
  .pu-hero__title--dark {
    top: calc(241.75 / var(--art-h) * 100%);
    color: #060623;
    line-height: 0.73;
    letter-spacing: calc(-4.0433 * var(--px));
    z-index: 2;
  }

  /* Figma 847:183 — bottom 470.75 + translateY(100%) ≈ top 253.5 in art coords */
  .pu-hero__title--yellow {
    top: calc(253.5 / var(--art-h) * 100%);
    color: #fceb00;
    line-height: 0.76;
    letter-spacing: calc(-4.0433 * var(--px));
    z-index: 3;
  }

  .pu-hero__patches {
    position: absolute;
    inset: 0;
    z-index: 6;
    pointer-events: none;
  }

  .pu-hero__patch {
    position: absolute;
    pointer-events: none;
  }

  .pu-hero__patch-inner {
    padding: calc(14.64 * var(--px)) calc(20 * var(--px));
    border-radius: calc(12 * var(--px));
    border-width: calc(1.8 * var(--px));
    line-height: 0.73;
    letter-spacing: calc(-0.56 * var(--px));
    font-size: calc(28 * var(--px));
    white-space: nowrap;
  }

  /* Figma 847:196 */
  .pu-hero__patch--for-every {
    left: calc(604 / var(--art-w) * 100%);
    top: calc(186 / var(--art-h) * 100%);
    transform: rotate(14.53deg);
  }

  .pu-hero__patch--for-every .pu-hero__patch-inner {
    font-size: calc(32 * var(--px));
    letter-spacing: calc(-0.64 * var(--px));
  }

  /* Figma 847:194 */
  .pu-hero__patch--theres-a {
    left: calc(147.16 / var(--art-w) * 100%);
    top: calc(400 / var(--art-h) * 100%);
    transform: rotate(-12.36deg) skewX(-2deg);
  }

  /* Figma 847:199 */
  .pu-hero__patch--you-do {
    left: calc(1126 / var(--art-w) * 100%);
    top: calc(316 / var(--art-h) * 100%);
    transform: rotate(-8.34deg);
  }

  .pu-hero__patch--you-do .pu-hero__patch-inner {
    font-size: calc(32 * var(--px));
    letter-spacing: calc(-0.64 * var(--px));
  }

  .pu-hero__fig {
    position: absolute;
    overflow: hidden;
    z-index: 4;
    pointer-events: none;
  }

  .pu-hero__fig img {
    position: absolute;
    display: block;
    max-width: none !important;
    width: auto !important;
    height: auto !important;
  }

  /* Figma 847:191 — figure on S */
  .pu-hero__fig--on-s {
    left: calc(452.54 / var(--art-w) * 100%);
    top: calc(161.54 / var(--art-h) * 100%);
    width: calc(94.367 * var(--px));
    height: calc(95.389 * var(--px));
    transform: rotate(6.13deg);
  }

  .pu-hero__fig--on-s img {
    width: 527.8% !important;
    height: 272.14% !important;
    left: -364.98%;
    top: -52.14%;
  }

  /* Figma 847:192 — figure on G */
  .pu-hero__fig--on-g {
    left: calc(1031.42 / var(--art-w) * 100%);
    top: calc(126.75 / var(--art-h) * 100%);
    width: calc(107.881 * var(--px));
    height: calc(111.175 * var(--px));
    transform: rotate(-18.54deg);
  }

  .pu-hero__fig--on-g img {
    width: 558.02% !important;
    height: 282.22% !important;
    left: -161.07%;
    top: -64.07%;
  }

  /* Figma 847:193 — sitting figure */
  .pu-hero__fig--sitting {
    left: calc(1078.58 / var(--art-w) * 100%);
    top: calc(413.53 / var(--art-h) * 100%);
    width: calc(130.845 * var(--px));
    height: calc(113.616 * var(--px));
    transform: rotate(10.06deg);
  }

  .pu-hero__fig--sitting img {
    width: 520.28% !important;
    height: 312.3% !important;
    left: -247.33%;
    top: -67.21%;
  }

  /* Figma 847:185 — running figure */
  .pu-hero__fig--runner {
    left: calc(154.48 / var(--art-w) * 100%);
    top: calc(454.85 / var(--art-h) * 100%);
    width: calc(103.562 * var(--px));
    height: calc(107.525 * var(--px));
    transform: rotate(29.94deg);
    overflow: visible;
  }

  .pu-hero__fig--runner img {
    position: relative;
    width: 100% !important;
    height: 100% !important;
    left: auto;
    top: auto;
    object-fit: contain;
  }

  /* Figma 847:198 — product bottle */
  .pu-hero__product-wrap {
    position: absolute;
    left: calc((573 + 502.27 - 25.59) / var(--art-w) * 100%);
    top: calc(406.43 / var(--art-h) * 100%);
    width: calc(51.18 * var(--px));
    height: calc(130.775 * var(--px));
    transform: rotate(12.2deg);
    z-index: 5;
    overflow: hidden;
    pointer-events: none;
  }

  .pu-hero__product {
    display: block;
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    object-fit: cover;
    object-position: center top;
  }

  /* Figma 847:201 */
  .pu-hero__cta {
    position: absolute;
    left: 50%;
    top: calc(592 * var(--scale) * 1px);
    transform: translateX(-50%);
    width: calc(174 * var(--scale) * 1px);
    min-height: calc(56 * var(--scale) * 1px);
    padding: calc(10 * var(--scale) * 1px) calc(16 * var(--scale) * 1px);
    font-size: calc(24 * var(--scale) * 1px);
    z-index: 4;
  }

  .pu-hero__tickers {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
  }

  .pu-hero__ticker {
    position: absolute;
    left: 50%;
    border: calc(1.8 * var(--scale) * 1px) solid #060623;
    border-radius: calc(13 * var(--scale) * 1px);
    box-shadow: var(--pu-shadow);
    padding: calc(14.64 * var(--scale) * 1px) calc(20 * var(--scale) * 1px);
    width: calc(1509 * var(--scale) * 1px);
  }

  .pu-hero__ticker span {
    font-family: var(--pu-font-display);
    font-size: calc(28 * var(--scale) * 1px);
    font-weight: 600;
    line-height: 0.73;
    letter-spacing: calc(-0.56 * var(--scale) * 1px);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Figma 847:167 */
  .pu-hero__ticker--white {
    top: calc(693 * var(--scale) * 1px);
    transform: translateX(-50%) rotate(-6.43deg) skewX(-2deg);
    background: #fff;
    color: #060623;
    z-index: 2;
  }

  /* Figma 847:175 */
  .pu-hero__ticker--orange {
    top: calc(806.66 * var(--scale) * 1px);
    transform: translateX(-50%) rotate(1.13deg) skewX(-2deg);
    background: #ff6800;
    color: #060623;
    z-index: 3;
  }

  @media (max-width: 749px) {
    .pu-hero__inner {
      min-height: auto;
      padding-bottom: 120px;
    }

    .pu-hero__fig,
    .pu-hero__product-wrap {
      display: none;
    }

    .pu-hero__title {
      white-space: normal;
      font-size: clamp(40px, 12vw, 72px);
      width: 100%;
    }

    .pu-hero__title--dark {
      top: 8%;
    }

    .pu-hero__title--yellow {
      top: 22%;
    }

    .pu-hero__patches {
      position: static;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      margin-top: 140px;
    }

    .pu-hero__patch {
      position: static;
      transform: none !important;
    }

    .pu-hero__cta {
      position: relative;
      top: auto;
      transform: none;
      margin: 24px auto 0;
    }

    .pu-hero__tickers {
      position: relative;
      width: 100%;
      left: auto;
      transform: none;
      margin-top: 40px;
    }

    .pu-hero__ticker--white,
    .pu-hero__ticker--orange {
      position: relative;
      top: auto;
      left: auto;
      transform: rotate(-4deg);
      width: 110%;
      margin-left: -5%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Hero",
  "class": "pu-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title line 1",
      "default": "SILLY THING"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title line 2",
      "default": "PLEASE UNDO"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "ticker_1_text",
      "label": "Ticker 1 text",
      "default": "it's human to mess up"
    },
    {
      "type": "text",
      "id": "ticker_2_text",
      "label": "Ticker 2 text",
      "default": "your right to a quick reset"
    }
  ],
  "blocks": [
    {
      "type": "patch",
      "name": "White patch",
      "settings": [
        {
          "type": "select",
          "id": "content_type",
          "label": "Content type",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "image", "label": "Image or SVG file" },
            { "value": "html", "label": "Custom HTML / inline SVG" }
          ],
          "default": "text"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Patch text"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image or SVG file"
        },
        {
          "type": "html",
          "id": "html",
          "label": "Custom HTML or inline SVG"
        },
        {
          "type": "range",
          "id": "position_top",
          "label": "Vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0
        },
        {
          "type": "range",
          "id": "position_left",
          "label": "Left position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0,
          "info": "Use 0 when positioning from the right"
        },
        {
          "type": "range",
          "id": "position_right",
          "label": "Right position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0,
          "info": "Overrides left when greater than 0"
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Rotation",
          "min": -45,
          "max": 45,
          "step": 1,
          "unit": "deg",
          "default": 0
        },
        {
          "type": "range",
          "id": "parallax_y",
          "label": "Scroll drift (vertical)",
          "min": 0,
          "max": 120,
          "step": 2,
          "unit": "px",
          "default": 30
        },
        {
          "type": "range",
          "id": "parallax_x",
          "label": "Scroll drift (horizontal)",
          "min": -40,
          "max": 40,
          "step": 2,
          "unit": "px",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Hero",
      "blocks": [
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "For every"
          }
        },
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "There's a"
          }
        },
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "you do"
          }
        }
      ]
    }
  ]
}
{% endschema %}
