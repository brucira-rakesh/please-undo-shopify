<section class="pu-hero" data-pu-hero>
  <div class="pu-hero__texture pu-texture-overlay"></div>
  <div class="pu-hero__content">
    <div class="pu-hero__typography">
      <div class="pu-hero__patches">
        {% assign patch_blocks = section.blocks | where: 'type', 'patch' %}
        {% if patch_blocks.size > 0 %}
          {% for block in patch_blocks %}
            {% case forloop.index0 %}
              {% when 0 %}
                {% assign patch_style = '--patch-top: -14%; --patch-left: 42%; --patch-rotate: 12deg; --patch-top-mobile: -14%; --patch-left-mobile: 42%; --patch-rotate-mobile: 12deg;' %}
                {% assign patch_parallax_y = 28 %}
                {% assign patch_parallax_x = -6 %}
              {% when 1 %}
                {% assign patch_style = '--patch-top: 60%; --patch-left: 9%; --patch-rotate: -14deg;' %}
                {% assign patch_parallax_y = 42 %}
                {% assign patch_parallax_x = 8 %}
              {% when 2 %}
                {% assign patch_style = '--patch-top: 30%; --patch-right: 12%; --patch-rotate: -6deg;' %}
                {% assign patch_parallax_y = 36 %}
                {% assign patch_parallax_x = -10 %}
              {% else %}
                {% assign patch_style = '--patch-top: 50%; --patch-left: 50%; --patch-rotate: 0deg;' %}
                {% assign patch_parallax_y = 30 %}
                {% assign patch_parallax_x = 0 %}
            {% endcase %}
            {% render 'pu-hero-patch',
              block: block,
              patch_style: patch_style,
              parallax_y: patch_parallax_y,
              parallax_x: patch_parallax_x
            %}
          {% endfor %}
        {% else %}
          {% render 'pu-hero-patch',
            text: 'For every',
            patch_style: '--patch-top: -14%; --patch-left: 42%; --patch-rotate: 12deg; --patch-top-mobile: 0%; --patch-left-mobile: 48%; --patch-rotate-mobile: 12deg;',
            parallax_y: 28,
            parallax_x: -6
          %}
          {% render 'pu-hero-patch',
            text: "There's a",
            patch_style: '--patch-top: 60%; --patch-left: 9%; --patch-rotate: -14deg;',
            parallax_y: 42,
            parallax_x: 8
          %}
          {% render 'pu-hero-patch',
            text: 'you do',
            patch_style: '--patch-top: 30%; --patch-right: 12%; --patch-rotate: -6deg;',
            parallax_y: 36,
            parallax_x: -10
          %}
        {% endif %}
      </div>

      <h1 class="pu-hero__title pu-hero__title--dark">{{ section.settings.title_line_1 | default: 'SILLY THING' }}</h1>
      <h1 class="pu-hero__title pu-hero__title--yellow">
        {{ section.settings.title_line_2 | default: 'Please Undo' }}
      </h1>

      <div
        class="pu-hero__figure-wrap pu-hero__figure-wrap--1"
        data-pu-parallax
        data-parallax-y="55"
        data-parallax-x="12"
      >
        <img
          class="pu-hero__figure pu-hero__figure--1"
          src="{{ 'pu-stick-figure-1.png' | asset_url }}"
          alt=""
          width="104"
          height="105"
          loading="eager"
        >
      </div>
      <div
        class="pu-hero__figure-wrap pu-hero__figure-wrap--2"
        data-pu-parallax
        data-parallax-y="70"
        data-parallax-x="-8"
      >
        <img
          class="pu-hero__figure pu-hero__figure--2"
          src="{{ 'pu-stick-figure-2.svg' | asset_url }}"
          alt=""
          width="138"
          height="140"
          loading="eager"
        >
      </div>
      <div
        class="pu-hero__figure-wrap pu-hero__figure-wrap--3"
        data-pu-parallax
        data-parallax-y="48"
        data-parallax-x="-14"
      >
        <img
          class="pu-hero__figure pu-hero__figure--3"
          src="{{ 'pu-stick-figure-3.svg' | asset_url }}"
          alt=""
          width="149"
          height="135"
          loading="eager"
        >
      </div>
      <div
        class="pu-hero__figure-wrap pu-hero__figure-wrap--4"
        data-pu-parallax
        data-parallax-y="38"
        data-parallax-x="10"
      >
        <img
          class="pu-hero__figure pu-hero__figure--4"
          src="{{ 'pu-stick-figure-4.svg' | asset_url }}"
          alt=""
          width="138"
          height="140"
          loading="eager"
        >
      </div>
      <div class="pu-hero__product-wrap" data-pu-parallax data-parallax-y="62" data-parallax-x="-6">
        {% if section.settings.product_image != blank %}
          {{
            section.settings.product_image
            | image_url: width: 200
            | image_tag: class: 'pu-hero__product', alt: 'Please Undo product', loading: 'eager'
          }}
        {% else %}
          <img
            class="pu-hero__product"
            src="{{ 'pu-product-mockup.png' | asset_url }}"
            alt="Please Undo product"
            width="78"
            height="139"
            loading="eager"
          >
        {% endif %}
      </div>
    </div>

    {% if section.settings.button_label != blank %}
      <a
        href="{{ section.settings.button_link | default: routes.all_products_collection_url }}"
        class="pu-btn pu-btn--yellow pu-hero__cta"
      >
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>

  <div class="pu-hero__tickers">
    <div class="pu-hero__ticker pu-hero__ticker--white">
      <div class="pu-ticker">
        <div class="pu-ticker__track">
          {% assign ticker_1 = section.settings.ticker_1_text | default: "it's human to mess up" %}
          {% for i in (1..2) %}
            <div class="pu-ticker__group">
              {% for j in (1..10) %}
                <span>{{ ticker_1 }}</span>
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
    <div class="pu-hero__ticker pu-hero__ticker--orange">
      <div class="pu-ticker pu-ticker--reverse">
        <div class="pu-ticker__track">
          {% assign ticker_2 = section.settings.ticker_2_text | default: 'your right to a quick reset' %}
          {% for i in (1..2) %}
            <div class="pu-ticker__group">
              {% for j in (1..10) %}
                <span>{{ ticker_2 }}</span>
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-hero {
    position: relative;
    min-height: 851px;
    background: var(--pu-blue-bright);
    padding-top: calc(40px + var(--header-group-height, 88px));
    overflow: visible;
  }

  .pu-hero__content {
    position: relative;
    z-index: 2;
    max-width: 1500px;
    margin: 0 auto;
    padding: 100px 32px 200px;
    text-align: center;
  }

  .pu-hero__typography {
    position: relative;
    min-height: 280px;
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pu-hero__title {
    margin: 0 auto;
    max-width: 100%;
    font-family: var(--pu-font-display);
    font-weight: 800;
    font-size: 202px;
    line-height: 0.76;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .pu-hero__title--dark {
    color: var(--pu-navy-text);
    position: relative;
    z-index: 2;
  }

  .pu-hero__title--yellow {
    color: var(--pu-yellow);
    margin-top: -20px;
  }

  .pu-hero__patches {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }

  .pu-hero__patch {
    position: absolute;
    top: var(--patch-top, 50%);
    left: var(--patch-left, auto);
    right: var(--patch-right, auto);
    transform: rotate(var(--patch-rotate, 0deg));
    pointer-events: none;
  }

  .pu-hero__patch-inner {
    font-size: clamp(20px, 2.5vw, 32px);
    line-height: 1;
    white-space: nowrap;
  }

  .pu-hero__patch-media {
    display: block;
    width: auto !important;
    max-width: clamp(48px, 8vw, 120px) !important;
    height: auto !important;
  }

  .pu-hero__patch-html {
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .pu-hero__patch-html svg {
    width: clamp(32px, 5vw, 64px);
    height: auto;
    display: block;
  }

  .pu-hero__patch-drift {
    will-change: transform;
  }

  .pu-hero__figure-wrap,
  .pu-hero__product-wrap {
    position: absolute;
    will-change: transform;
    z-index: 3;
  }

  .pu-hero__figure-wrap--1 {
    top: 68%;
    left: 11%;
  }
  .pu-hero__figure-wrap--2 {
    top: -30%;
    left: 31%;
  }
  .pu-hero__figure-wrap--3 {
    top: -34%;
    right: 18%;
  }
  .pu-hero__figure-wrap--4 {
    top: 61.5%;
    right: 14%;
  }

  .pu-hero__product-wrap {
    top: 52%;
    right: 12%;
    z-index: 4;
  }

  .pu-hero__figure {
    position: relative;
    object-fit: contain;
    display: block;
    max-width: none !important;
    height: auto !important;
  }

  .pu-hero__figure--1 {
    width: 104px !important;
    transform: rotate(30deg);
  }
  .pu-hero__figure--2 {
    width: 120px !important;
    transform: rotate(3deg);
  }
  .pu-hero__figure--3 {
    width: 130px !important;
    transform: rotate(0deg);
  }
  .pu-hero__figure--4 {
    width: 140px !important;
    transform: rotate(0deg);
  }

  .pu-hero__product {
    width: 51px !important;
    max-width: 51px !important;
    height: auto !important;
    transform: rotate(12deg);
    display: block;
  }

  .pu-hero__cta {
    position: relative;
    z-index: 3;
  }

  .pu-hero__tickers {
    --ticker-bleed: 140vw;
    position: absolute;
    bottom: 0;
    left: 50%;
    z-index: 5;
    width: var(--ticker-bleed);
    transform: translateX(-50%);
    pointer-events: none;
    overflow: visible;
  }

  .pu-hero__ticker {
    padding: 0;
    border: 1.8px solid var(--pu-navy-text);
    border-radius: 13px;
    box-shadow: var(--pu-shadow);
    margin: 0;
    width: 100%;
    transform-origin: center center;
    overflow: hidden;
  }

  .pu-hero__ticker .pu-ticker {
    overflow: hidden;
    width: 100%;
  }

  .pu-hero__ticker span {
    flex-shrink: 0;
    font-family: var(--pu-font-display);
    font-size: clamp(18px, 2vw, 28px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.56px;
    white-space: nowrap;
  }

  .pu-hero__ticker--white {
    background: var(--pu-white);
    color: var(--pu-navy-text);
    transform: rotate(-6deg) skew(1deg);
    margin-bottom: -12px;
    position: relative;
    z-index: 2;
    width: 108%;
    margin-left: -4%;
  }

  .pu-hero__ticker--orange {
    background: var(--pu-orange);
    color: var(--pu-navy-text);
    transform: rotate(1.12deg) skewX(-1deg);
    position: relative;
    z-index: 3;
    width: 106%;
    margin-left: -3%;
  }

  @media (max-width: 749px) {
    .pu-hero {
      min-height: auto;
      overflow: visible;
      padding-top: calc(16px + var(--header-group-height, 64px));
    }

    .pu-hero__content {
      padding: 32px 16px 148px;
      overflow: visible;
    }

    .pu-hero__typography {
      position: relative;
      min-height: clamp(220px, 62vw, 300px);
      margin-bottom: 24px;
      overflow: visible;
    }

    .pu-hero__title {
      font-size: clamp(72px, 24vw, 96px);
      line-height: 0.82;
    }

    .pu-hero__title--yellow {
      margin-top: -8px;
    }

    .pu-hero__figure-wrap--1 {
      top: 68%;
      left: 10%;
    }

    .pu-hero__figure-wrap--2 {
      top: 4%;
      left: 26%;
    }

    .pu-hero__figure-wrap--3 {
      top: 26%;
      right: 16%;
    }

    .pu-hero__figure-wrap--4 {
      top: 80%;
      right: 14%;
    }

    .pu-hero__product-wrap {
      top: 76%;
      right: 10%;
      z-index: 2;
    }

    .pu-hero__figure--1 {
      width: 56px !important;
    }

    .pu-hero__figure--2 {
      width: 64px !important;
    }

    .pu-hero__figure--3 {
      width: 70px !important;
    }

    .pu-hero__figure--4 {
      width: 76px !important;
    }

    .pu-hero__product {
      width: 36px !important;
      max-width: 36px !important;
    }

    .pu-hero__patches {
      position: static;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      margin-bottom: 16px;
    }

    .pu-hero__patch {
      position: static;
      transform: rotate(var(--patch-rotate, 0deg)) !important;
    }

    .pu-hero__tickers {
      --ticker-bleed: 112vw;
      width: var(--ticker-bleed);
      left: 50%;
      transform: translateX(-50%);
      bottom: -4px;
    }

    .pu-hero__ticker {
      border-radius: 10px;
    }

    .pu-hero__ticker span {
      font-size: clamp(13px, 3.4vw, 17px);
      letter-spacing: -0.32px;
    }

    .pu-hero__ticker .pu-ticker__group {
      gap: 14px;
    }

    .pu-hero__ticker--white {
      width: 100%;
      margin-left: 0;
      transform: rotate(-3.5deg);
      margin-bottom: 4px;
      z-index: 2;
    }

    .pu-hero__ticker--orange {
      width: 100%;
      margin-left: 0;
      transform: rotate(2deg);
      z-index: 3;
    }

    .pu-hero__ticker .pu-ticker {
      padding: 7px 0;
    }
  }

  @media (max-width: 389px) {
    .pu-hero__ticker span {
      font-size: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Hero",
  "class": "pu-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title line 1",
      "default": "SILLY THING"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title line 2",
      "default": "Please Undo"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "ticker_1_text",
      "label": "Ticker 1 text",
      "default": "it's human to mess up"
    },
    {
      "type": "text",
      "id": "ticker_2_text",
      "label": "Ticker 2 text",
      "default": "your right to a quick reset"
    }
  ],
  "blocks": [
    {
      "type": "patch",
      "name": "White patch",
      "settings": [
        {
          "type": "select",
          "id": "content_type",
          "label": "Content type",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "image", "label": "Image or SVG file" },
            { "value": "html", "label": "Custom HTML / inline SVG" }
          ],
          "default": "text"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Patch text"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image or SVG file"
        },
        {
          "type": "html",
          "id": "html",
          "label": "Custom HTML or inline SVG"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Hero",
      "blocks": [
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "For every"
          }
        },
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "There's a"
          }
        },
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "you do"
          }
        }
      ]
    }
  ]
}
{% endschema %}
