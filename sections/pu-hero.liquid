<section class="pu-hero" data-pu-hero>
  <div class="pu-hero__texture pu-texture-overlay"></div>
  <div class="pu-hero__content">
    <div class="pu-hero__typography">
      <div class="pu-hero__patches">
        {% assign patch_blocks = section.blocks | where: 'type', 'patch' %}
        {% if patch_blocks.size > 0 %}
          {% for block in patch_blocks %}
            {% render 'pu-hero-patch', block: block %}
          {% endfor %}
        {% else %}
          <div
            class="pu-hero__patch"
            style="--patch-top: 6%; --patch-left: 38%; --patch-rotate: 12deg;"
          >
            <div class="pu-hero__patch-drift" data-pu-parallax data-parallax-y="28" data-parallax-x="-6">
              <div class="pu-sticker pu-hero__patch-inner"><span>For every</span></div>
            </div>
          </div>
          <div
            class="pu-hero__patch"
            style="--patch-top: 37%; --patch-left: 5%; --patch-rotate: -14deg;"
          >
            <div class="pu-hero__patch-drift" data-pu-parallax data-parallax-y="42" data-parallax-x="8">
              <div class="pu-sticker pu-hero__patch-inner"><span>There's a</span></div>
            </div>
          </div>
          <div
            class="pu-hero__patch"
            style="--patch-top: 20%; --patch-right: 12%; --patch-rotate: -6deg;"
          >
            <div class="pu-hero__patch-drift" data-pu-parallax data-parallax-y="36" data-parallax-x="-10">
              <div class="pu-sticker pu-hero__patch-inner"><span>you do</span></div>
            </div>
          </div>
        {% endif %}
      </div>

      <h1 class="pu-hero__title pu-hero__title--dark">{{ section.settings.title_line_1 | default: 'SILLY THING' }}</h1>
      <h1 class="pu-hero__title pu-hero__title--yellow">
        {{ section.settings.title_line_2 | default: 'Please Undo' }}
      </h1>

      <div
        class="pu-hero__figure-wrap pu-hero__figure-wrap--1"
        data-pu-parallax
        data-parallax-y="55"
        data-parallax-x="12"
      >
        <img
          class="pu-hero__figure pu-hero__figure--1"
          src="{{ 'pu-stick-figure-1.png' | asset_url }}"
          alt=""
          width="104"
          height="105"
          loading="eager"
        >
      </div>
      <div
        class="pu-hero__figure-wrap pu-hero__figure-wrap--2"
        data-pu-parallax
        data-parallax-y="70"
        data-parallax-x="-8"
      >
        <img
          class="pu-hero__figure pu-hero__figure--2"
          src="{{ 'pu-stick-figure-2.png' | asset_url }}"
          alt=""
          width="138"
          height="140"
          loading="eager"
        >
      </div>
      <div
        class="pu-hero__figure-wrap pu-hero__figure-wrap--3"
        data-pu-parallax
        data-parallax-y="48"
        data-parallax-x="-14"
      >
        <img
          class="pu-hero__figure pu-hero__figure--3"
          src="{{ 'pu-stick-figure-2.png' | asset_url }}"
          alt=""
          width="149"
          height="135"
          loading="eager"
        >
      </div>
      <div class="pu-hero__product-wrap" data-pu-parallax data-parallax-y="62" data-parallax-x="-6">
        {% if section.settings.product_image != blank %}
          {{
            section.settings.product_image
            | image_url: width: 200
            | image_tag: class: 'pu-hero__product', alt: 'Please Undo product', loading: 'eager'
          }}
        {% else %}
          <img
            class="pu-hero__product"
            src="{{ 'pu-product-mockup.png' | asset_url }}"
            alt="Please Undo product"
            width="78"
            height="139"
            loading="eager"
          >
        {% endif %}
      </div>
    </div>

    {% if section.settings.button_label != blank %}
      <a
        href="{{ section.settings.button_link | default: routes.all_products_collection_url }}"
        class="pu-btn pu-btn--yellow pu-hero__cta"
      >
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>

  <div class="pu-hero__tickers">
    <div class="pu-hero__ticker pu-hero__ticker--white">
      <div class="pu-ticker">
        <div class="pu-ticker__track">
          {% assign ticker_1 = section.settings.ticker_1_text | default: "it's human to mess up" %}
          {% for i in (1..2) %}
            <div class="pu-ticker__group">
              {% for j in (1..10) %}
                <span>{{ ticker_1 }}</span>
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
    <div class="pu-hero__ticker pu-hero__ticker--orange">
      <div class="pu-ticker pu-ticker--reverse">
        <div class="pu-ticker__track">
          {% assign ticker_2 = section.settings.ticker_2_text | default: 'your right to a quick reset' %}
          {% for i in (1..2) %}
            <div class="pu-ticker__group">
              {% for j in (1..10) %}
                <span>{{ ticker_2 }}</span>
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-hero {
    position: relative;
    min-height: 851px;
    background: var(--pu-blue-bright);
    padding-top: calc(40px + var(--header-group-height, 88px));
    overflow: visible;
  }

  .pu-hero__content {
    position: relative;
    z-index: 2;
    max-width: 100%;
    margin: 0 auto;
    padding: 100px 32px 200px;
    text-align: center;
  }

  .pu-hero__typography {
    position: relative;
    min-height: 480px;
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pu-hero__title {
    margin: 0 auto;
    max-width: 100%;
    font-family: var(--pu-font-display);
    font-weight: 800;
    font-size: clamp(48px, 11.5vw, 202px);
    line-height: 0.76;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .pu-hero__title--dark {
    color: var(--pu-navy-text);
    position: relative;
    z-index: 2;
  }

  .pu-hero__title--yellow {
    color: var(--pu-yellow);
    margin-top: -20px;
  }

  .pu-hero__patches {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }

  .pu-hero__patch {
    position: absolute;
    top: var(--patch-top, 50%);
    left: var(--patch-left, auto);
    right: var(--patch-right, auto);
    transform: rotate(var(--patch-rotate, 0deg));
    pointer-events: none;
  }

  .pu-hero__patch-inner {
    font-size: clamp(20px, 2.5vw, 32px);
    line-height: 1;
    white-space: nowrap;
  }

  .pu-hero__patch-media {
    display: block;
    width: auto !important;
    max-width: clamp(48px, 8vw, 120px) !important;
    height: auto !important;
  }

  .pu-hero__patch-html {
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .pu-hero__patch-html svg {
    width: clamp(32px, 5vw, 64px);
    height: auto;
    display: block;
  }

  .pu-hero__patch-drift {
    will-change: transform;
  }

  .pu-hero__figure-wrap,
  .pu-hero__product-wrap {
    position: absolute;
    will-change: transform;
    z-index: 3;
  }

  .pu-hero__figure-wrap--1 {
    top: 52%;
    left: 12%;
  }
  .pu-hero__figure-wrap--2 {
    top: 8%;
    left: 30%;
  }
  .pu-hero__figure-wrap--3 {
    top: 42%;
    right: 12%;
  }

  .pu-hero__product-wrap {
    top: 42%;
    right: 18%;
    z-index: 4;
  }

  .pu-hero__figure {
    position: relative;
    object-fit: contain;
    display: block;
    max-width: none !important;
    height: auto !important;
  }

  .pu-hero__figure--1 {
    width: 104px !important;
    transform: rotate(30deg);
  }
  .pu-hero__figure--2 {
    width: 120px !important;
    transform: rotate(-18deg);
  }
  .pu-hero__figure--3 {
    width: 130px !important;
    transform: rotate(10deg);
  }

  .pu-hero__product {
    width: 78px !important;
    max-width: 78px !important;
    height: auto !important;
    transform: rotate(12deg);
    display: block;
  }

  .pu-hero__cta {
    position: relative;
    z-index: 3;
  }

  .pu-hero__tickers {
    --ticker-bleed: 140vw;
    position: absolute;
    bottom: 0;
    left: 50%;
    z-index: 5;
    width: var(--ticker-bleed);
    transform: translateX(-50%);
    pointer-events: none;
    overflow: visible;
  }

  .pu-hero__ticker {
    padding: 0;
    border: 1.8px solid var(--pu-navy-text);
    border-radius: 13px;
    box-shadow: var(--pu-shadow);
    margin: 0;
    width: 100%;
    transform-origin: center center;
    overflow: hidden;
  }

  .pu-hero__ticker .pu-ticker {
    overflow: hidden;
    width: 100%;
  }

  .pu-hero__ticker span {
    flex-shrink: 0;
    font-family: var(--pu-font-display);
    font-size: clamp(18px, 2vw, 28px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.56px;
    white-space: nowrap;
  }

  .pu-hero__ticker--white {
    background: var(--pu-white);
    color: var(--pu-navy-text);
    transform: rotate(-6deg) skew(1deg);
    margin-bottom: -12px;
    position: relative;
    z-index: 2;
    width: 108%;
    margin-left: -4%;
  }

  .pu-hero__ticker--orange {
    background: var(--pu-orange);
    color: var(--pu-navy-text);
    transform: rotate(1.12deg) skewX(-1deg);
    position: relative;
    z-index: 3;
    width: 106%;
    margin-left: -3%;
  }

  @media (max-width: 749px) {
    .pu-hero__typography {
      min-height: 360px;
    }
    .pu-hero__figure-wrap,
    .pu-hero__product-wrap {
      display: none;
    }
    .pu-hero__patches {
      position: static;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      margin-bottom: 16px;
    }

    .pu-hero__patch {
      position: static;
      transform: rotate(var(--patch-rotate, 0deg)) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Hero",
  "class": "pu-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title line 1",
      "default": "SILLY THING"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title line 2",
      "default": "Please Undo"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "ticker_1_text",
      "label": "Ticker 1 text",
      "default": "it's human to mess up"
    },
    {
      "type": "text",
      "id": "ticker_2_text",
      "label": "Ticker 2 text",
      "default": "your right to a quick reset"
    }
  ],
  "blocks": [
    {
      "type": "patch",
      "name": "White patch",
      "settings": [
        {
          "type": "select",
          "id": "content_type",
          "label": "Content type",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "image", "label": "Image or SVG file" },
            { "value": "html", "label": "Custom HTML / inline SVG" }
          ],
          "default": "text"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Patch text"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image or SVG file"
        },
        {
          "type": "html",
          "id": "html",
          "label": "Custom HTML or inline SVG"
        },
        {
          "type": "range",
          "id": "position_top",
          "label": "Vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0
        },
        {
          "type": "range",
          "id": "position_left",
          "label": "Left position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0,
          "info": "Use 0 when positioning from the right"
        },
        {
          "type": "range",
          "id": "position_right",
          "label": "Right position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0,
          "info": "Overrides left when greater than 0"
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Rotation",
          "min": -45,
          "max": 45,
          "step": 1,
          "unit": "deg",
          "default": 0
        },
        {
          "type": "range",
          "id": "parallax_y",
          "label": "Scroll drift (vertical)",
          "min": 0,
          "max": 120,
          "step": 2,
          "unit": "px",
          "default": 30
        },
        {
          "type": "range",
          "id": "parallax_x",
          "label": "Scroll drift (horizontal)",
          "min": -40,
          "max": 40,
          "step": 2,
          "unit": "px",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Hero",
      "blocks": [
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "For every",
            "position_top": 8,
            "position_left": 38,
            "rotation": 15,
            "parallax_y": 28,
            "parallax_x": -6
          }
        },
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "There's a",
            "position_top": 58,
            "position_left": 8,
            "rotation": -12,
            "parallax_y": 42,
            "parallax_x": 8
          }
        },
        {
          "type": "patch",
          "settings": {
            "content_type": "text",
            "text": "you do",
            "position_top": 38,
            "position_right": 8,
            "rotation": -8,
            "parallax_y": 36,
            "parallax_x": -10
          }
        }
      ]
    }
  ]
}
{% endschema %}
