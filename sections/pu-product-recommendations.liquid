  {% liquid
  assign intent = section.settings.intent | default: 'related'
  if section.settings.type == 'complementary'
    assign intent = 'complementary'
  elsif section.settings.type == 'related'
    assign intent = 'related'
  endif
  assign limit = section.settings.max_products | default: 4
  assign bg_class = ''
  if section.settings.background == 'blue'
    assign bg_class = ' pu-pdp-recs--blue'
  elsif section.settings.background == 'gray'
    assign bg_class = ' pu-pdp-recs--alt'
  endif
%}

<section
  class="pu-pdp-recs pu-pdp-animate{{ bg_class }}"
  data-pu-recs
  data-product-id="{{ product.id }}"
  data-intent="{{ intent }}"
  data-limit="{{ limit }}"
  {% if section.settings.type == 'recently_viewed' %}data-pu-recently-section{% endif %}
>
  <div class="pu-pdp-recs__inner">
    <h2 class="pu-pdp-recs__title">{{ section.settings.title }}</h2>

    {% if section.settings.type == 'manual' and section.settings.collection != blank %}
      <div class="pu-pdp-recs__grid">
        {% assign shown = 0 %}
        {% for item in section.settings.collection.products %}
          {% if item.id != product.id and shown < limit %}
            {% render 'pu-product-card', product: item %}
            {% assign shown = shown | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
    {% elsif section.settings.type == 'recently_viewed' %}
      <div class="pu-pdp-recs__scroll" data-pu-recently-viewed data-product-handle="{{ product.handle }}"></div>
    {% else %}
      <div
        class="{% if section.settings.layout == 'scroll' %}pu-pdp-recs__scroll{% else %}pu-pdp-recs__grid{% endif %}"
        data-pu-recs-grid
      ></div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "PU Product Recs",
  "tag": "section",
  "class": "pu-pdp-recs-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "select",
      "id": "type",
      "label": "Source",
      "options": [
        { "value": "related", "label": "Related products (Shopify)" },
        { "value": "complementary", "label": "Complete the look" },
        { "value": "manual", "label": "Manual collection" },
        { "value": "recently_viewed", "label": "Recently viewed" }
      ],
      "default": "related"
    },
    {
      "type": "select",
      "id": "intent",
      "label": "Recommendation intent",
      "options": [
        { "value": "related", "label": "Related" },
        { "value": "complementary", "label": "Complementary" }
      ],
      "default": "related",
      "info": "Used for Shopify recommendation API"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "For manual source only"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "scroll", "label": "Horizontal scroll" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "gray", "label": "Gray" },
        { "value": "blue", "label": "Blue" }
      ],
      "default": "white"
    }
  ],
  "presets": [
    {
      "name": "PU Product Recs",
      "settings": {
        "title": "You may also like",
        "type": "related"
      }
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
