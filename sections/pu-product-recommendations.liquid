{% liquid
  assign showcase_collection = section.settings.collection
  assign limit = section.settings.products_count | default: 3
  assign columns = section.settings.columns | default: 3
%}

<section class="pu-pdp-recs" id="pu-pdp-recs">
  <div class="pu-pdp-recs__inner">
    <header class="pu-pdp-recs__header">
      <img class="pu-pdp-recs__spark" src="{{ 'pu-grid-spark-left.png' | asset_url }}" alt="" width="32" height="32" loading="lazy">
      <h2 class="pu-pdp-recs__title">{{ section.settings.heading | default: 'More undos' }}</h2>
      <img class="pu-pdp-recs__spark" src="{{ 'pu-grid-spark-right.png' | asset_url }}" alt="" width="32" height="32" loading="lazy">
    </header>

    {% if showcase_collection != blank and showcase_collection.products_count > 0 %}
      <div
        class="pu-pdp-recs__grid"
        style="--pu-showcase-columns: {{ columns }};"
        data-pu-showcase-grid
        {{ section.shopify_attributes }}
      >
        {% assign shown = 0 %}
        {% for showcase_product in showcase_collection.products %}
          {% if section.settings.hide_current_product and showcase_product.id == product.id %}
            {% continue %}
          {% endif %}
          {% if shown >= limit %}
            {% break %}
          {% endif %}
          {% render 'pu-product-card',
            product: showcase_product,
            index: shown | plus: 1,
            section_id: section.id
          %}
          {% assign shown = shown | plus: 1 %}
        {% endfor %}
      </div>
    {% else %}
      <p class="pu-pdp-recs__empty">{{ section.settings.empty_message | default: 'Choose a collection in the theme editor.' }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "PU Collection Showcase",
  "class": "pu-product-recs-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More undos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "hide_current_product",
      "label": "Hide current product",
      "default": true
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Empty state message",
      "default": "Choose a collection in the theme editor."
    }
  ],
  "presets": [{ "name": "PU Collection Showcase" }]
}
{% endschema %}
