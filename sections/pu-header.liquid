{% liquid
  assign shop_menu = linklists[section.settings.shop_menu]
%}

<link rel="stylesheet" href="{{ 'pu-home.css' | asset_url }}">

<header-component
  id="header-component"
  class="pu-header-component"
  transparent="always"
  data-skip-node-update
>
  <div ref="headerDrawerContainer" hidden aria-hidden="true"></div>
  <div ref="headerMenu" hidden aria-hidden="true"></div>

  <div ref="headerRowTop" class="pu-header__row">
    <header class="pu-header" data-pu-header>
      <div class="pu-header__inner">
        <nav class="pu-header__nav" aria-label="Primary">
          <div class="pu-header__nav-item pu-header__nav-item--dropdown">
            <a href="{{ section.settings.shop_link | default: routes.collections_url }}" class="pu-header__link">
              {{ section.settings.shop_label | default: 'Shop' }}
              <svg class="pu-header__chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="#060622" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            {% if shop_menu.links.size > 0 %}
              <ul class="pu-header__dropdown">
                {% for link in shop_menu.links %}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
          <a
            href="{{ section.settings.about_link | default: '/pages/about' }}"
            class="pu-header__nav-item pu-header__link"
          >
            {{ section.settings.about_label | default: 'About' }}
          </a>
        </nav>

        <nav class="pu-header__mobile-nav" aria-label="Primary mobile">
          <a href="{{ section.settings.shop_link | default: routes.collections_url }}" class="pu-header__mobile-link">
            {{ section.settings.shop_label | default: 'Shop' }}
          </a>
          <a href="{{ section.settings.about_link | default: '/pages/about' }}" class="pu-header__mobile-link">
            {{ section.settings.about_label | default: 'About' }}
          </a>
        </nav>

        <a href="{{ routes.root_url }}" class="pu-header__logo" aria-label="{{ shop.name }}">
          {% if section.settings.logo != blank %}
            {{ section.settings.logo | image_url: width: 200 | image_tag: loading: 'eager', alt: shop.name }}
          {% else %}
            <img src="{{ 'pu-logo.png' | asset_url }}" alt="{{ shop.name }}" width="91" height="75" loading="eager">
          {% endif %}
        </a>

        <div class="pu-header__actions">
          <button type="button" class="pu-header__icon-btn" aria-label="Search" data-pu-search-open>
            <img src="{{ 'pu-icon-search.png' | asset_url }}" alt="" width="19" height="19">
          </button>
          <a href="/" class="pu-header__icon-btn" aria-label="Account">
            <img src="{{ 'pu-icon-heart.png' | asset_url }}" alt="" width="18" height="18">
          </a>
          <a href="/" class="pu-header__icon-btn" aria-label="Cart">
            <img src="{{ 'pu-icon-cart.png' | asset_url }}" alt="" width="18" height="18">
            {% if cart.item_count > 0 %}
              <span class="pu-header__cart-count">{{ cart.item_count }}</span>
            {% endif %}
          </a>
        </div>
      </div>
    </header>
  </div>
</header-component>

{% stylesheet %}
  .pu-header-section.shopify-section,
  #header-group:has(.pu-header-section) {
    background: transparent !important;
  }

  #header-component.pu-header-component {
    display: block;
    background: transparent !important;
    opacity: 1 !important;
  }

  #header-component.pu-header-component[transparent] {
    --transparent-header-offset-boolean: 1;
  }

  .pu-header__row {
    display: block;
  }

  .pu-header {
    position: relative;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1;
    height: 88px;
    background: transparent;
    pointer-events: auto;
  }

  .pu-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 90%;
    margin: 0 auto;
    padding: 24px 32px;
    height: 100%;
  }

  .pu-header__nav {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-self: start;
  }

  .pu-header__nav-item {
    position: relative;
  }

  .pu-header__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 12px;
    background: var(--pu-white);
    border: var(--pu-border);
    border-radius: 8px;
    font-family: var(--pu-font-display);
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.48px;
    text-transform: uppercase;
    color: var(--pu-navy-text);
    text-decoration: none;
    line-height: 32px;
    white-space: nowrap;
  }

  /* Override theme base.css img { width: 100% } */
  .pu-header img {
    width: auto;
    max-width: none;
    height: auto;
  }

  .pu-header__chevron {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: block;
  }

  .pu-header__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 180px;
    margin: 0;
    padding: 8px 0;
    list-style: none;
    background: var(--pu-white);
    border: var(--pu-border);
    border-radius: 8px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
    z-index: 10;
  }

  .pu-header__nav-item--dropdown:hover .pu-header__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .pu-header__dropdown a {
    display: block;
    padding: 8px 16px;
    font-family: var(--pu-font-body);
    font-size: 14px;
    color: var(--pu-navy);
    text-decoration: none;
  }

  .pu-header__dropdown a:hover {
    background: var(--pu-gray);
  }

  .pu-header__logo {
    justify-self: center;
    display: block;
    line-height: 0;
    flex-shrink: 0;
  }

  .pu-header__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-self: end;
  }

  .pu-header__icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--pu-white);
    border: var(--pu-border);
    border-radius: 48px;
    cursor: pointer;
    text-decoration: none;
    padding: 0;
    flex-shrink: 0;
  }

  .pu-header__icon-btn img {
    width: 18px;
    height: 18px;
    object-fit: contain;
  }

  .pu-header__logo img {
    height: 75px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
  }

  .pu-header__cart-count {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    background: var(--pu-orange);
    color: var(--pu-white);
    font-size: 11px;
    font-weight: 600;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pu-header__mobile-nav {
    display: none;
  }

  .pu-header__mobile-link {
    font-family: var(--pu-font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--pu-navy-text);
    text-decoration: none;
    text-transform: uppercase;
  }

  @media (max-width: 749px) {
    .pu-header {
      height: auto;
      min-height: 64px;
    }

    .pu-header__inner {
      padding: 10px 12px;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      grid-template-rows: auto;
      column-gap: 8px;
      align-items: center;
    }

    .pu-header__nav {
      display: none;
    }

    .pu-header__logo {
      grid-column: 2;
      grid-row: 1;
    }

    .pu-header__logo img {
      height: 48px;
      max-width: 72px;
    }

    .pu-header__actions {
      grid-column: 3;
      grid-row: 1;
      justify-self: end;
      gap: 6px;
    }

    .pu-header__icon-btn {
      width: 34px;
      height: 34px;
    }

    .pu-header__icon-btn img {
      width: 16px;
      height: 16px;
    }

    .pu-header__mobile-nav {
      display: flex;
      grid-column: 1;
      grid-row: 1;
      justify-self: start;
      align-items: center;
      gap: 6px;
      padding-bottom: 0;
    }

    .pu-header__mobile-link {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      background: var(--pu-white);
      border: var(--pu-border);
      border-radius: 6px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: -0.26px;
      line-height: 22px;
      white-space: nowrap;
    }
  }

  @media (max-width: 389px) {
    .pu-header__mobile-link {
      font-size: 12px;
      padding: 2px 6px;
      line-height: 20px;
    }

    .pu-header__logo img {
      height: 44px;
      max-width: 64px;
    }

    .pu-header__icon-btn {
      width: 32px;
      height: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Header",
  "class": "header-section pu-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Shop label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "shop_link",
      "label": "Shop link"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop dropdown menu"
    },
    {
      "type": "text",
      "id": "about_label",
      "label": "About label",
      "default": "About"
    },
    {
      "type": "url",
      "id": "about_link",
      "label": "About link"
    }
  ],
  "presets": [
    {
      "name": "PU Header"
    }
  ]
}
{% endschema %}
