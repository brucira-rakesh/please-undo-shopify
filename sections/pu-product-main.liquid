{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign form_id = 'pu-product-form-' | append: section.id
  assign category_label = section.settings.category_label
  if category_label == blank and product.metafields.custom.category != blank
    assign category_label = product.metafields.custom.category
  endif
  if category_label == blank
    assign category_label = 'LAPTOP NECK'
  endif

  assign show_compare = false
  if current_variant.compare_at_price > current_variant.price
    assign show_compare = true
  endif
%}

<section
  class="pu-pdp-hero"
  data-pu-product-main
  id="pu-pdp-hero"
  data-money-format="{{ shop.money_format | escape }}"
>
  <div class="pu-pdp-hero__texture pu-texture-overlay" aria-hidden="true"></div>

  <div class="pu-pdp-hero__layout">
    <div class="pu-pdp-hero__visual">
      <div class="pu-pdp-hero__stage">
        <div class="pu-pdp-hero__product">
          {% if product.featured_media %}
            <img
              src="{{ product.featured_media | image_url: width: 800 }}"
              alt="{{ product.featured_media.alt | default: product.title | escape }}"
              width="291"
              height="744"
              loading="eager"
              data-pu-product-main-image
            >
          {% else %}
            <img
              src="{{ 'pu-product-mockup.png' | asset_url }}"
              alt="{{ product.title | escape }}"
              width="291"
              height="744"
              loading="eager"
              data-pu-product-main-image
            >
          {% endif %}
        </div>
        <div class="pu-pdp-hero__shadow" aria-hidden="true"></div>

        {% comment %}
          <div class="pu-pdp-hero__figure" aria-hidden="true">
            {% if section.settings.figure_image != blank %}
              {{
                section.settings.figure_image
                | image_url: width: 600
                | image_tag: loading: 'lazy', alt: '', class: 'pu-pdp-hero__figure-img'
              }}
            {% else %}
              <img
                class="pu-pdp-hero__figure-img"
                src="{{ 'laptop-pain.svg' | asset_url }}"
                alt=""
                width="274"
                height="332"
                loading="lazy"
              >
            {% endif %}
          </div>
        {% endcomment %}
      </div>

      <div class="pu-pdp-hero__gallery-grid" data-pu-gallery-grid>
        {% if product.media.size > 0 %}
          {% for media in product.media limit: 8 %}
            <button
              type="button"
              class="pu-pdp-hero__gallery-item{% if forloop.first %} is-active{% endif %}"
              data-pu-media-id="{{ media.id }}"
              aria-label="{{ media.alt | default: product.title | escape }}"
              aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              {{
                media.preview_image
                | image_url: width: 240
                | image_tag: loading: 'lazy', alt: '', class: 'pu-pdp-hero__gallery-img'
              }}
            </button>
          {% endfor %}
        {% else %}
          <button
            type="button"
            class="pu-pdp-hero__gallery-item is-active"
            data-pu-media-id="fallback"
            aria-current="true"
            aria-label="{{ product.title | escape }}"
          >
            <img
              src="{{ 'pu-product-mockup.png' | asset_url }}"
              alt=""
              class="pu-pdp-hero__gallery-img"
              width="120"
              height="120"
              loading="lazy"
            >
          </button>
        {% endif %}
      </div>
    </div>

    <div class="pu-pdp-hero__buy">
      <div class="pu-pdp-hero__meta">
        <p class="pu-pdp-hero__category">{{ category_label }}</p>
        <h1 class="pu-pdp-hero__title">{{ product.title }}</h1>
        <p class="pu-pdp-hero__price">
          {% if show_compare %}
            <s data-pu-product-compare>{{ current_variant.compare_at_price | money }}</s>
          {% else %}
            <s data-pu-product-compare hidden></s>
          {% endif %}
          <span data-pu-product-price>{{ current_variant.price | money }}</span>
        </p>
      </div>

      {% if section.settings.bullet_points != blank %}
        {%- comment -%}
          bullet_points can come from a richtext setting (<p> items) or a
          dynamic source bound to a list metafield (<ul><li> items) —
          normalize both to <p> so the numbering below always lines up.
        {%- endcomment -%}
        {% assign bullet_html = section.settings.bullet_points
          | replace: '<li>', '<p>'
          | replace: '</li>', '</p>'
          | replace: '<ul>', ''
          | replace: '</ul>', ''
          | replace: '<ol>', ''
          | replace: '</ol>', ''
        %}
        <div class="pu-pdp-hero__bullets">
          <div class="pu-pdp-hero__bullet-nums" aria-hidden="true">
            {% assign bullet_parts = bullet_html | split: '<p>' %}
            {% assign bullet_index = 0 %}
            {% for part in bullet_parts %}
              {% assign part_text = part | strip_html | strip %}
              {% if part_text != blank %}
                {% assign bullet_index = bullet_index | plus: 1 %}
                <span>{{ bullet_index }}</span>
              {% endif %}
            {% endfor %}
          </div>
          <div class="pu-pdp-hero__bullet-text rte">{{ bullet_html }}</div>
        </div>
      {% endif %}

      {% if product.has_only_default_variant == false %}
        <div class="pu-pdp-hero__variants" role="group" aria-label="Product variants">
          {% for variant in product.variants %}
            <button
              type="button"
              class="pu-pdp-hero__variant{% if variant.id == current_variant.id %} is-active{% endif %}"
              data-pu-variant-id="{{ variant.id }}"
              {% unless variant.available %}
                disabled
              {% endunless %}
            >
              {{ variant.title }}
            </button>
          {% endfor %}
        </div>
      {% endif %}

      <div class="pu-pdp-hero__cta">
        {% comment %}
          {% if section.settings.features_label != blank %}
            <a href="#pu-pdp-details" class="pu-pdp-hero__btn-outline" data-pu-scroll-features>
              {{ section.settings.features_label }}
            </a>
          {% endif %}
        {% endcomment %}

        <product-form-component
          class="pu-pdp-hero__form"
          data-section-id="{{ section.id }}"
          data-product-id="{{ product.id }}"
          data-product-url="{{ product.url }}"
          on:submit="/handleSubmit"
        >
          <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
          {%- form 'product', product, id: form_id, data-type: 'add-to-cart-form' -%}
            <input type="hidden" name="id" ref="variantId" value="{{ current_variant.id }}">
            <span class="product-form-text__error hidden" ref="addToCartTextError"></span>
            <button
              type="submit"
              name="add"
              class="pu-btn pu-btn--yellow pu-pdp-hero__btn-buy"
              ref="addToCartButton"
              data-label-available="{{ section.settings.add_to_cart_label | default: 'SHOP NOW' }}"
              {% unless current_variant.available %}
                disabled
              {% endunless %}
            >
              {% if current_variant.available %}
                {{ section.settings.add_to_cart_label | default: 'SHOP NOW' }}
              {% else %}
                {{ 'products.product.sold_out' | t | default: 'SOLD OUT' }}
              {% endif %}
            </button>
          {%- endform -%}
        </product-form-component>
      </div>
    </div>
  </div>

  <nav class="pu-pdp-hero__progress" aria-label="Page sections" data-pu-pdp-progress>
    {% assign section_count = 4 %}
    {% for i in (1..section_count) %}
      <a
        href="#{% case i %}{% when 1 %}pu-pdp-story{% when 2 %}pu-pdp-use{% when 3 %}pu-pdp-details{% when 4 %}pu-pdp-recs{% endcase %}"
        class="pu-pdp-hero__progress-seg{% if forloop.first %} is-active{% endif %}"
        data-pu-pdp-progress-seg
        data-section-index="{{ forloop.index0 }}"
      ></a>
    {% endfor %}
    {% for i in (5..33) %}
      <span class="pu-pdp-hero__progress-seg is-faded" aria-hidden="true"></span>
    {% endfor %}
  </nav>

  <script type="application/json" data-pu-product-json>
    {{ product | json }}
  </script>
</section>

<div class="pu-pdp-sticky" data-pu-pdp-sticky hidden>
  <div class="pu-pdp-sticky__inner">
    <div class="pu-pdp-sticky__info">
      <p class="pu-pdp-sticky__title">{{ product.title }}</p>
      <p class="pu-pdp-sticky__price" data-pu-sticky-price>{{ current_variant.price | money }}</p>
    </div>
    <button type="button" class="pu-btn pu-btn--yellow pu-pdp-sticky__btn" data-pu-sticky-add>
      {{ section.settings.add_to_cart_label | default: 'SHOP NOW' }}
    </button>
  </div>
</div>

{% schema %}
{
  "name": "PU Product Main",
  "class": "pu-product-main-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "category_label",
      "label": "Category label",
      "default": "LAPTOP NECK"
    },
    {
      "type": "richtext",
      "id": "bullet_points",
      "label": "Feature bullets",
      "default": "<p>Low smell</p><p>0 Stain</p><p>Daily use</p>"
    },
    {
      "type": "text",
      "id": "features_label",
      "label": "Features button label",
      "default": "VIEW FEATURES"
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Add to cart label",
      "default": "SHOP NOW"
    },
    {
      "type": "image_picker",
      "id": "figure_image",
      "label": "Side illustration"
    }
  ],
  "presets": [{ "name": "PU Product Main" }]
}
{% endschema %}
