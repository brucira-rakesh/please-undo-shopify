<section class="pu-pdp-details" id="pu-pdp-details">
  <div class="pu-pdp-details__band">
    <h2 class="pu-pdp-details__heading">{{ section.settings.heading | default: 'The fine print' }}</h2>
  </div>

  <div class="pu-pdp-details__inner">
    <div class="pu-pdp-details__grid">
      <div class="pu-pdp-details__accordion">
        {% if section.settings.show_description and product.description != blank %}
          <details class="pu-pdp-details__item" open>
            <summary class="pu-pdp-details__summary">
              <span>{{ section.settings.description_label | default: 'Description' }}</span>
            </summary>
            <div class="pu-pdp-details__body rte">{{ product.description }}</div>
          </details>
        {% endif %}

        {% for block in section.blocks %}
          <details class="pu-pdp-details__item"{% if block.settings.open_by_default %} open{% endif %} {{ block.shopify_attributes }}>
            <summary class="pu-pdp-details__summary">
              <span>{{ block.settings.title }}</span>
            </summary>
            <div class="pu-pdp-details__body rte">{{ block.settings.content }}</div>
          </details>
        {% endfor %}
      </div>

      <aside class="pu-pdp-details__aside">
        <div class="pu-pdp-details__card">
          <p class="pu-pdp-details__card-label">{{ section.settings.card_label | default: 'Volume' }}</p>
          <p class="pu-pdp-details__card-value">{{ section.settings.card_value | default: '40 ML' }}</p>
        </div>
        <div class="pu-pdp-details__card pu-pdp-details__card--yellow">
          <p class="pu-pdp-details__card-label">{{ section.settings.card_label_2 | default: 'Use' }}</p>
          <p class="pu-pdp-details__card-value">{{ section.settings.card_value_2 | default: 'Daily' }}</p>
        </div>
        <img
          class="pu-pdp-details__figure"
          src="{{ 'pu-stick-figure-footer.png' | asset_url }}"
          alt=""
          width="120"
          height="130"
          loading="lazy"
        >
      </aside>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PU Product Details",
  "class": "pu-product-details-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The fine print"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description",
      "default": true
    },
    {
      "type": "text",
      "id": "description_label",
      "label": "Description tab label",
      "default": "Description"
    },
    {
      "type": "text",
      "id": "card_label",
      "label": "Info card 1 label",
      "default": "Volume"
    },
    {
      "type": "text",
      "id": "card_value",
      "label": "Info card 1 value",
      "default": "40 ML"
    },
    {
      "type": "text",
      "id": "card_label_2",
      "label": "Info card 2 label",
      "default": "Use"
    },
    {
      "type": "text",
      "id": "card_value_2",
      "label": "Info card 2 value",
      "default": "Daily"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Ingredients"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>See packaging for the full ingredient list.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Product Details",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "title": "Ingredients",
            "content": "<p>See packaging for the full ingredient list.</p>"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "title": "Shipping & returns",
            "content": "<p>Standard shipping rates apply. Contact us if you need an undo on your order.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
