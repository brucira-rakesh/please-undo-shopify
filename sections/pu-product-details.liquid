<section class="pu-pdp-details pu-pdp-animate">
  <div class="pu-pdp-details__inner">
    {% if section.settings.title != blank %}
      <h2 class="pu-pdp-details__title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="pu-pdp-accordion" data-pu-accordion data-single="true">
      {% for block in section.blocks %}
        <div class="pu-pdp-accordion__item{% if forloop.first %} is-open{% endif %}" data-pu-accordion-item {{ block.shopify_attributes }}>
          <button
            type="button"
            class="pu-pdp-accordion__trigger"
            data-pu-accordion-trigger
            aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="accordion-panel-{{ block.id }}"
            id="accordion-trigger-{{ block.id }}"
          >
            {{ block.settings.heading }}
            <svg class="pu-pdp-accordion__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <div
            class="pu-pdp-accordion__panel"
            id="accordion-panel-{{ block.id }}"
            role="region"
            aria-labelledby="accordion-trigger-{{ block.id }}"
          >
            <div class="pu-pdp-accordion__content">
              <div class="pu-pdp-accordion__body rte">
                {% case block.type %}
                  {% when 'description' %}
                    {{ product.description }}
                  {% else %}
                    {{ block.settings.content }}
                {% endcase %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PU Product Details",
  "tag": "section",
  "class": "pu-pdp-details-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Product details"
    }
  ],
  "blocks": [
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Tab heading",
          "default": "Description"
        }
      ]
    },
    {
      "type": "tab",
      "name": "Custom tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Tab heading",
          "default": "Features"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<ul><li>Fast-absorbing formula</li><li>Low smell, zero stain</li><li>Safe for daily use</li></ul>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Product Details",
      "blocks": [
        { "type": "description", "settings": { "heading": "Description" } },
        { "type": "tab", "settings": { "heading": "Features", "content": "<ul><li>Fast-absorbing formula</li><li>Low smell, zero stain</li><li>Safe for daily use</li></ul>" } },
        { "type": "tab", "settings": { "heading": "Materials", "content": "<p>Natural essential oils, menthol, and skin-friendly carriers.</p>" } },
        { "type": "tab", "settings": { "heading": "Care Instructions", "content": "<p>Store in a cool, dry place. Roll directly on affected area.</p>" } },
        { "type": "tab", "settings": { "heading": "Shipping", "content": "<p>Ships within 24 hours. Free delivery on orders over ₹499.</p>" } },
        { "type": "tab", "settings": { "heading": "FAQs", "content": "<p><strong>How often can I use it?</strong><br>Daily, as needed.</p>" } }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
