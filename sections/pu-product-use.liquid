<section class="pu-pdp-use" id="pu-pdp-use">
  <div class="pu-pdp-use__bg" aria-hidden="true">
    <div class="pu-pdp-use__orange"></div>
    <img class="pu-pdp-use__arc" src="{{ 'pu-orange-arc.png' | asset_url }}" alt="" width="1440" height="629" loading="lazy">
    <div class="pu-pdp-use__texture pu-texture-overlay"></div>
  </div>

  <div class="pu-pdp-use__inner">
    <header class="pu-pdp-use__header">
      <img class="pu-pdp-use__spark" src="{{ 'pu-spark-left.png' | asset_url }}" alt="" width="32" height="32" loading="lazy">
      <h2 class="pu-pdp-use__title">{{ section.settings.heading | default: 'How to Undo' }}</h2>
      <img class="pu-pdp-use__spark" src="{{ 'pu-spark-right.png' | asset_url }}" alt="" width="32" height="32" loading="lazy">
    </header>

    <div class="pu-pdp-use__steps">
      {% for block in section.blocks %}
        <article class="pu-pdp-use__step pu-pdp-use__step--{{ forloop.index }}" {{ block.shopify_attributes }}>
          <span class="pu-pdp-use__step-num">{{ forloop.index }}</span>
          <h3 class="pu-pdp-use__step-title">{{ block.settings.title }}</h3>
          <p class="pu-pdp-use__step-text">{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PU Product How-To",
  "class": "pu-product-use-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to Undo"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Roll it on"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Glide over neck and shoulders where tension lives."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Product How-To",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Roll it on",
            "text": "Glide over neck and shoulders where tension lives."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Wait a beat",
            "text": "Give it a few seconds — relief kicks in fast."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Get back to it",
            "text": "Low smell, zero stain. Keep it at your desk."
          }
        }
      ]
    }
  ]
}
{% endschema %}
