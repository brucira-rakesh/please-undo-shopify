<section class="pu-green-ticker">
  <div class="pu-green-ticker__skew">
    <div class="pu-green-ticker__bar">
      <div class="pu-green-ticker__marquee" aria-hidden="true">
        <div class="pu-green-ticker__track">
          {% for i in (1..2) %}
            {% for j in (1..6) %}
              <span>{{ section.settings.phrase_1 | default: 'you do you' }}</span>
              <span>{{ section.settings.phrase_2 | default: 'we JUST UNDO' }}</span>
            {% endfor %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-green-ticker {
    background: var(--pu-white);
    padding: 24px 0 0;
    overflow: hidden;
  }

  .pu-green-ticker__skew {
    transform: skewX(-2deg);
    margin: 0 -24px;
  }

  .pu-green-ticker__bar {
    background: var(--pu-green);
    border: 1.8px solid #000;
    border-radius: 13px;
    margin-bottom: -1px;
    box-shadow: var(--pu-shadow);
    overflow: hidden;
  }

  .pu-green-ticker__marquee {
    overflow: hidden;
    padding: 14.64px 0;
  }

  .pu-green-ticker__track {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    width: max-content;
    animation: pu-green-ticker-scroll 28s linear infinite;
    will-change: transform;
  }

  .pu-green-ticker__track span {
    flex-shrink: 0;
    font-family: var(--pu-font-display);
    font-size: clamp(18px, 1.94vw, 28px);
    font-weight: 600;
    line-height: 0.73;
    text-transform: uppercase;
    letter-spacing: -0.56px;
    color: var(--pu-white);
    white-space: nowrap;
  }

  @keyframes pu-green-ticker-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pu-green-ticker__track {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Green Ticker",
  "class": "pu-green-ticker-section",
  "settings": [
    {
      "type": "text",
      "id": "phrase_1",
      "label": "Phrase 1",
      "default": "you do you"
    },
    {
      "type": "text",
      "id": "phrase_2",
      "label": "Phrase 2",
      "default": "we JUST UNDO"
    }
  ],
  "presets": [{ "name": "PU Green Ticker" }]
}
{% endschema %}
