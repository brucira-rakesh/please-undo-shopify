{% liquid
  assign rating_value = product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value | default: section.settings.fallback_rating
  assign rating_count = product.metafields.reviews.rating_count.value | default: section.settings.fallback_count
  assign full_stars = rating_value | floor
%}

<section class="pu-pdp-reviews pu-pdp-animate" id="pu-reviews">
  <div class="pu-pdp-reviews__inner">
    <h2 class="pu-pdp-details__title">{{ section.settings.title | default: 'Customer reviews' }}</h2>

    {% if rating_value != blank and rating_count > 0 %}
      <div class="pu-pdp-reviews__header">
        <div class="pu-pdp-reviews__score">
          <div class="pu-pdp-reviews__score-num">{{ rating_value }}</div>
          <div class="pu-pdp__stars" aria-label="{{ rating_value }} out of 5 stars">
            {% for i in (1..5) %}
              {% if i <= full_stars %}
                <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.35l-4.94 2.6.94-5.5-4-3.9 5.53-.8L10 1.5z"/></svg>
              {% else %}
                <svg class="is-empty" viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.35l-4.94 2.6.94-5.5-4-3.9 5.53-.8L10 1.5z"/></svg>
              {% endif %}
            {% endfor %}
          </div>
          <p class="pu-pdp__rating-count">{{ rating_count }} reviews</p>
        </div>

        <div class="pu-pdp-reviews__breakdown">
          {% assign counts = '5,4,3,2,1' | split: ',' %}
          {% for star in counts %}
            {% assign star_num = star | plus: 0 %}
            {% assign bar_pct = 0 %}
            {% if rating_count > 0 %}
              {% comment %} Approximate breakdown when per-star data unavailable {% endcomment %}
              {% if star_num == 5 %}
                {% assign bar_pct = 72 %}
              {% elsif star_num == 4 %}
                {% assign bar_pct = 18 %}
              {% elsif star_num == 3 %}
                {% assign bar_pct = 6 %}
              {% elsif star_num == 2 %}
                {% assign bar_pct = 3 %}
              {% else %}
                {% assign bar_pct = 1 %}
              {% endif %}
            {% endif %}
            <div class="pu-pdp-reviews__bar-row">
              <span>{{ star_num }}★</span>
              <div class="pu-pdp-reviews__bar" aria-hidden="true">
                <div class="pu-pdp-reviews__bar-fill" style="width: {{ bar_pct }}%;"></div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <div class="pu-pdp-reviews__list">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <article class="pu-pdp-review" {{ block.shopify_attributes }}>
            <div class="pu-pdp-review__top">
              <div>
                <div class="pu-pdp__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {% assign review_stars = block.settings.rating | floor %}
                  {% for i in (1..5) %}
                    {% if i <= review_stars %}
                      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.35l-4.94 2.6.94-5.5-4-3.9 5.53-.8L10 1.5z"/></svg>
                    {% else %}
                      <svg class="is-empty" viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.35l-4.94 2.6.94-5.5-4-3.9 5.53-.8L10 1.5z"/></svg>
                    {% endif %}
                  {% endfor %}
                </div>
                <p class="pu-pdp-review__author">{{ block.settings.author }}</p>
              </div>
              {% if block.settings.date != blank %}
                <time class="pu-pdp-review__date" datetime="{{ block.settings.date }}">{{ block.settings.date }}</time>
              {% endif %}
            </div>
            {% if block.settings.title != blank %}
              <p class="pu-pdp-review__author">{{ block.settings.title }}</p>
            {% endif %}
            <p class="pu-pdp-review__text">{{ block.settings.body }}</p>
          </article>
        {% endfor %}
      {% else %}
        <p class="pu-pdp__excerpt">Reviews will appear here when connected to Shopify Product Reviews or a reviews app.</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PU Product Reviews",
  "tag": "section",
  "class": "pu-pdp-reviews-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Customer reviews"
    },
    {
      "type": "range",
      "id": "fallback_rating",
      "label": "Fallback rating (no app)",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 4.8
    },
    {
      "type": "number",
      "id": "fallback_count",
      "label": "Fallback review count",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Verified buyer"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review body",
          "default": "Works exactly as described. Quick relief without the strong smell."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "March 2026"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PU Product Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "author": "Priya S.",
            "title": "Instant relief",
            "body": "Works exactly as described. Quick relief without the strong smell.",
            "date": "March 2026"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "author": "Arjun M.",
            "title": "Daily essential",
            "body": "I keep this on my desk. Laptop neck is gone and it doesn't stain my shirts.",
            "date": "February 2026"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
