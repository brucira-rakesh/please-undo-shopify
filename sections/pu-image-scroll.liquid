{% liquid
  assign sequence_basename = section.settings.sequence_basename | strip
  assign sequence_frames = section.settings.sequence_frame_count | default: 411
  assign sequence_pad = section.settings.sequence_pad_digits | default: 5
  assign sequence_start = section.settings.sequence_start_number | default: 0
  assign sequence_first_suffix = section.settings.sequence_first_frame | default: '00000' | strip
  assign has_sequence = false
  if sequence_basename != blank
    assign has_sequence = true
    assign sequence_first_file = sequence_basename | append: sequence_first_suffix | append: '.png'
  endif
%}

<section class="pu-image-scroll" data-pu-image-scroll>
  <div
    class="pu-image-scroll__purple{% if has_sequence %} pu-image-scroll__purple--sequence{% endif %}"
    data-pu-scroll-purple
    {% if has_sequence %}data-pu-scroll-sequence-pin{% endif %}
  >
    <img
      class="pu-image-scroll__rays{% if has_sequence %} pu-image-scroll__rays--sequence-fallback{% endif %}"
      src="{{ 'pu-purple-rays.png' | asset_url }}"
      alt=""
      width="1441"
      height="927"
      {% unless has_sequence %}loading="lazy"{% endunless %}
      {% if has_sequence %}fetchpriority="high"{% endif %}
    >
    <div class="pu-image-scroll__texture pu-texture-overlay"></div>

    {% if has_sequence %}
      <div
        class="pu-image-scroll__sequence"
        data-pu-scroll-sequence
        data-sequence-frames="{{ sequence_frames }}"
        data-sequence-pad="{{ sequence_pad }}"
        data-sequence-start="{{ sequence_start }}"
        data-sequence-basename="{{ sequence_basename }}"
        data-sequence-url="{{ sequence_first_file | asset_url }}"
        data-sequence-scroll-vh="{{ section.settings.sequence_scroll_vh | default: 120 }}"
        aria-label="{{ section.settings.sequence_alt | default: 'Every morning comes with a fresh start' }}"
      >
        <img
          class="pu-image-scroll__sequence-img"
          data-pu-sequence-frame
          src="{{ sequence_first_file | asset_url }}"
          alt=""
          width="1920"
          height="1080"
          fetchpriority="high"
          decoding="async"
        >
      </div>
    {% else %}
      <div class="pu-image-scroll__curved-text">
        <svg viewBox="0 0 1440 400" class="pu-image-scroll__text-svg" aria-hidden="true">
          <defs>
            <path id="pu-curve-top-{{ section.id }}" d="M-200,280 Q720,40 1640,280" fill="none"/>
            <path id="pu-curve-bottom-{{ section.id }}" d="M-100,320 Q720,80 1540,320" fill="none"/>
          </defs>
          <text class="pu-image-scroll__svg-text">
            <textPath href="#pu-curve-top-{{ section.id }}" startOffset="50%" text-anchor="middle">
              {{ section.settings.curve_text_1 | default: 'Every morning' }}
            </textPath>
          </text>
          <text class="pu-image-scroll__svg-text pu-image-scroll__svg-text--lower">
            <textPath href="#pu-curve-bottom-{{ section.id }}" startOffset="50%" text-anchor="middle">
              {{ section.settings.curve_text_2 | default: 'comes with a fresh start' }}
            </textPath>
          </text>
        </svg>
      </div>
    {% endif %}
  </div>

  <div class="pu-image-scroll__orange" data-pu-scroll-orange>
    <div class="pu-image-scroll__pin" data-pu-scroll-pin>
      <div class="pu-image-scroll__bg" aria-hidden="true">
        {% comment %}
          <div class="pu-image-scroll__bg-orange"></div>
          <img
            class="pu-image-scroll__arc"
            src="{{ 'pu-orange-arc.png' | asset_url }}"
            alt=""
            width="1440"
            height="629"
            loading="lazy"
          >
        {% endcomment %}
        <div class="pu-image-scroll__bg-green"></div>
        <img
          class="pu-image-scroll__green-arc"
          src="{{ 'pu-green-arc.png' | asset_url }}"
          alt=""
          width="1440"
          height="629"
          loading="lazy"
        >
        <div class="pu-image-scroll__texture pu-texture-overlay"></div>
      </div>

      <div class="pu-image-scroll__viewport">
        <div class="pu-image-scroll__track" data-pu-scroll-track>
          {% for block in section.blocks %}
            <div class="pu-image-scroll__slide" data-pu-scroll-image {{ block.shopify_attributes }}>
              <div class="pu-image-scroll__frame">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 1000
                    | image_tag: loading: 'lazy', class: 'pu-image-scroll__image', alt: block.settings.alt
                  }}
                {% else %}
                  <img
                    class="pu-image-scroll__image"
                    src="{{ block.settings.fallback_asset | default: 'pu-scroll-img-1.png' | asset_url }}"
                    alt="{{ block.settings.alt | escape }}"
                    loading="lazy"
                    width="485"
                    height="531"
                  >
                {% endif %}
                {% if block.settings.overlay_text != blank %}
                  <p
                    class="pu-image-scroll__overlay pu-image-scroll__overlay--{{ block.settings.overlay_position | default: 'bottom-left' }}"
                    style="--overlay-rotate: {{ block.settings.overlay_rotation | default: 0 }}deg"
                  >
                    {{- block.settings.overlay_text -}}
                  </p>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-image-scroll {
    position: relative;
    overflow: hidden;
  }

  .pu-image-scroll img {
    max-width: none !important;
  }

  .pu-image-scroll__purple {
    position: relative;
    z-index: 1;
    min-height: 800px;
    background: #4a1a8a;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .pu-image-scroll__rays {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }

  .pu-image-scroll__purple > .pu-image-scroll__texture {
    z-index: 1;
  }

  .pu-image-scroll__purple--sequence {
    min-height: 100svh;
    align-items: stretch;
    justify-content: stretch;
    background: #4a1a8a;
  }

  .pu-image-scroll__purple--sequence > .pu-image-scroll__texture {
    display: none;
  }

  .pu-image-scroll__rays--sequence-fallback {
    z-index: 1;
  }

  .pu-image-scroll__rays--sequence-fallback.is-hidden {
    opacity: 0;
    visibility: hidden;
  }

  .pu-image-scroll__sequence {
    position: relative;
    z-index: 2;
    width: 100%;
    flex: 1;
    min-height: 100svh;
    display: flex;
    align-items: stretch;
    justify-content: center;
  }

  .pu-image-scroll__sequence-img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100svh;
    object-fit: cover;
    object-position: center bottom;
  }

  .pu-image-scroll__curved-text {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 60px 0 140px;
  }

  .pu-image-scroll__text-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .pu-image-scroll__svg-text {
    fill: var(--pu-white);
    font-family: var(--pu-font-display);
    font-size: clamp(48px, 6.5vw, 72px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .pu-image-scroll__svg-text--lower {
    font-size: clamp(44px, 5.5vw, 64px);
  }

  .pu-image-scroll__orange {
    position: relative;
    z-index: 2;
    margin-top: -120px;
    overflow: hidden;
    background: var(--pu-orange);
  }

  .pu-image-scroll__pin {
    position: relative;
    min-height: 904px;
    overflow: hidden;
  }

  .pu-image-scroll__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .pu-image-scroll__bg-orange {
    position: absolute;
    inset: 0;
    background: var(--pu-orange);
  }

  .pu-image-scroll__arc {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: auto;
    z-index: 2;
  }

  .pu-image-scroll__bg-green {
    position: absolute;
    left: 0;
    right: 0;
    top: 46%;
    bottom: 0;
    background: var(--pu-orange);
    z-index: 1;
  }

  .pu-image-scroll__green-arc {
    position: absolute;
    top: 46%;
    left: 0;
    width: 100%;
    height: auto;
    transform: translateY(-58%);
    z-index: 3;
  }

  .pu-image-scroll__bg .pu-image-scroll__texture {
    z-index: 4;
  }

  .pu-image-scroll__viewport {
    position: relative;
    z-index: 5;
    width: 100%;
    overflow: hidden;
    padding: 72px 0;
  }

  .pu-image-scroll__track {
    display: flex;
    gap: 8px;
    align-items: flex-end;
    padding: 0 4vw;
    will-change: transform;
  }

  .pu-image-scroll__slide {
    flex: 0 0 clamp(240px, 32vw, 460px);
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.2));
  }

  .pu-image-scroll__slide:nth-child(3n + 1) {
    transform: translateY(24px) rotate(4deg);
  }

  .pu-image-scroll__slide:nth-child(3n + 2) {
    transform: translateY(44px) rotate(-5deg);
    margin-right: -8px;
  }

  .pu-image-scroll__slide:nth-child(3n) {
    transform: translateY(8px) rotate(-3deg);
  }

  .pu-image-scroll__frame {
    position: relative;
  }

  .pu-image-scroll__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .pu-image-scroll__overlay {
    position: absolute;
    z-index: 2;
    margin: 0;
    max-width: 75%;
    font-family: 'Homemade Apple', cursive;
    font-size: clamp(22px, 2.8vw, 36px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--pu-white);
    text-shadow: 0 0 12px rgba(255, 255, 255, 0.35), 0 1px 3px rgba(0, 0, 0, 0.45);
    pointer-events: none;
    white-space: pre-line;
  }

  .pu-image-scroll__overlay--bottom-left {
    bottom: 8%;
    left: 5%;
    text-align: left;
    font-size: 28px;
    font-weight: 400;
    font-size: 28px;
    line-height: 118%;
    letter-spacing: -2%;
    transform: rotate(-12deg);
  }

  .pu-image-scroll__overlay--top-right {
    top: -4%;
    right: 4%;
    text-align: right;
    font-family: Homemade Apple;
    font-weight: 400;
    font-size: 28px;
    line-height: 103%;
    letter-spacing: -2%;
    transform: rotate(8deg);
  }

  .pu-image-scroll__overlay--bottom-right {
    bottom: 8%;
    right: 5%;
    transform: rotate(calc(3deg + var(--overlay-rotate, 0deg)));
    text-align: right;
  }

  .pu-image-scroll__overlay--top-left {
    top: 6%;
    left: 5%;
    transform: rotate(calc(-3deg + var(--overlay-rotate, 0deg)));
    text-align: left;
  }

  @media (max-width: 749px) {
    .pu-image-scroll__purple {
      min-height: 420px;
    }

    .pu-image-scroll__purple--sequence {
      min-height: 100svh;
    }

    .pu-image-scroll__sequence,
    .pu-image-scroll__sequence-canvas {
      min-height: 100svh;
    }

    .pu-image-scroll__curved-text {
      padding: 32px 0 72px;
    }

    .pu-image-scroll__orange {
      margin-top: -48px;
      min-height: 100svh;
      background: transparent;
    }

    .pu-image-scroll__pin {
      position: relative;
      min-height: 100svh;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    /* Orange arc PNG tints the top band a different shade on narrow viewports */
    .pu-image-scroll__arc {
      display: none;
    }

    .pu-image-scroll__bg-orange {
      inset: 0;
    }

    .pu-image-scroll__bg-green {
      top: 0;
      background: var(--pu-orange);
    }

    .pu-image-scroll__green-arc {
      top: 38%;
    }

    .pu-image-scroll__viewport {
      padding: 24px 0;
      flex: 0 0 auto;
      position: relative;
      z-index: 5;
    }

    .pu-image-scroll__track {
      padding: 0 16px;
    }

    .pu-image-scroll__slide {
      flex: 0 0 clamp(200px, 72vw, 320px);
    }

    .pu-image-scroll__slide:nth-child(3n + 1) {
      transform: translateY(12px) rotate(4deg);
    }

    .pu-image-scroll__slide:nth-child(3n + 2) {
      transform: translateY(20px) rotate(-5deg);
    }

    .pu-image-scroll__slide:nth-child(3n) {
      transform: translateY(4px) rotate(-3deg);
    }

    .pu-image-scroll__overlay--bottom-left,
    .pu-image-scroll__overlay--top-right {
      font-size: clamp(16px, 4.5vw, 22px);
    }

    .pu-image-scroll__image {
      max-width: 100% !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Image Scroll",
  "class": "pu-image-scroll-section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "image",
      "name": "Scroll image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "default": "pu-scroll-img-1.png"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        },
        {
          "type": "header",
          "content": "Handwritten overlay"
        },
        {
          "type": "textarea",
          "id": "overlay_text",
          "label": "Overlay text",
          "info": "Optional script-style caption on the image. Use line breaks for multiple lines."
        },
        {
          "type": "select",
          "id": "overlay_position",
          "label": "Text position",
          "options": [
            { "value": "bottom-left", "label": "Bottom left" },
            { "value": "top-right", "label": "Top right" },
            { "value": "bottom-right", "label": "Bottom right" },
            { "value": "top-left", "label": "Top left" }
          ],
          "default": "bottom-left"
        },
        {
          "type": "range",
          "id": "overlay_rotation",
          "label": "Extra rotation",
          "min": -20,
          "max": 20,
          "step": 1,
          "unit": "deg",
          "default": 0
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "PNG scroll sequence"
    },
    {
      "type": "text",
      "id": "sequence_basename",
      "label": "Sequence image basename",
      "default": "Seq_",
      "info": "Shared prefix before the frame number. Example: Seq_ for Seq_00000.png … Seq_00410.png. Upload all frames to Online Store → Themes → Edit code → Assets (not Settings → Files)."
    },
    {
      "type": "text",
      "id": "sequence_first_frame",
      "label": "First frame number",
      "default": "00000",
      "info": "Leading zeros included — must match your first file (e.g. 00000 for Seq_00000.png)."
    },
    {
      "type": "number",
      "id": "sequence_frame_count",
      "label": "Total frames",
      "default": 411
    },
    {
      "type": "select",
      "id": "sequence_pad_digits",
      "label": "Frame number digits",
      "default": "5",
      "options": [
        { "value": "3", "label": "3 (001)" },
        { "value": "4", "label": "4 (0001)" },
        { "value": "5", "label": "5 (00000)" },
        { "value": "6", "label": "6 (000000)" }
      ]
    },
    {
      "type": "number",
      "id": "sequence_start_number",
      "label": "First frame index",
      "default": 0,
      "info": "Numeric value of the first frame. Use 0 when files start at 00000."
    },
    {
      "type": "range",
      "id": "sequence_scroll_vh",
      "label": "Scroll length",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "vh",
      "default": 120,
      "info": "How far to scroll while playing through all frames."
    },
    {
      "type": "text",
      "id": "sequence_alt",
      "label": "Sequence accessibility label",
      "default": "Every morning comes with a fresh start"
    },
    {
      "type": "header",
      "content": "Static curved text fallback"
    },
    {
      "type": "paragraph",
      "content": "Shown only when no sequence basename is set."
    },
    {
      "type": "text",
      "id": "curve_text_1",
      "label": "Curved text line 1",
      "default": "Every morning"
    },
    {
      "type": "text",
      "id": "curve_text_2",
      "label": "Curved text line 2",
      "default": "comes with a fresh start"
    }
  ],
  "presets": [
    {
      "name": "PU Image Scroll",
      "blocks": [
        {
          "type": "image",
          "settings": {
            "fallback_asset": "pu-scroll-img-1.png",
            "alt": "Lifestyle",
            "overlay_text": "I have a 9 am meeting\nShould I have the 5th drink?",
            "overlay_position": "bottom-left"
          }
        },
        {
          "type": "image",
          "settings": {
            "fallback_asset": "pu-scroll-img-3.png",
            "alt": "Dogs"
          }
        },
        {
          "type": "image",
          "settings": {
            "fallback_asset": "pu-scroll-img-2.png",
            "alt": "Concert",
            "overlay_text": "The concert ended.\nThe ache got an encore.",
            "overlay_position": "top-right"
          }
        }
      ]
    }
  ]
}
{% endschema %}
