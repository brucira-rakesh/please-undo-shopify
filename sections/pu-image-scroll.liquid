{% liquid
  assign sequence_basename = section.settings.sequence_basename | strip
  assign sequence_frames = section.settings.sequence_frame_count | default: 357
  assign sequence_pad = section.settings.sequence_pad_digits | default: 5
  assign sequence_start = section.settings.sequence_start_number | default: 54
  assign sequence_first_suffix = section.settings.sequence_first_frame | default: '00054' | strip
  assign sequence_handoff = section.settings.sequence_handoff_frame | default: 380
  assign sequence_storage = section.settings.sequence_storage | default: 'shop_files'
  assign gallery_set_scroll = section.settings.gallery_set_scroll_vh | default: 55
  assign has_sequence = false
  if sequence_basename != blank
    assign has_sequence = true
    assign sequence_first_file = sequence_basename | append: sequence_first_suffix | append: '.png'
    if sequence_storage == 'theme_assets'
      assign sequence_first_url = sequence_first_file | asset_url
    else
      assign sequence_first_url = sequence_first_file | file_url
    endif
  endif
%}

<section class="pu-image-scroll{% if has_sequence %} pu-image-scroll--has-sequence{% endif %}" data-pu-image-scroll>
  {% if has_sequence %}
    <div class="pu-image-scroll__stage" data-pu-scroll-stage>
      <div class="pu-image-scroll__sequence-layer is-active" data-pu-scroll-sequence-pin>
        <div
          class="pu-image-scroll__sequence"
          data-pu-scroll-sequence
          data-sequence-frames="{{ sequence_frames }}"
          data-sequence-pad="{{ sequence_pad }}"
          data-sequence-start="{{ sequence_start }}"
          data-sequence-basename="{{ sequence_basename }}"
          data-sequence-url="{{ sequence_first_url }}"
          data-sequence-storage="{{ sequence_storage }}"
          data-sequence-handoff-frame="{{ sequence_handoff }}"
          data-sequence-scroll-vh="{{ section.settings.sequence_scroll_vh | default: 120 }}"
          aria-label="{{ section.settings.sequence_alt | default: 'Every morning comes with a fresh start' }}"
        >
          <div class="pu-image-scroll__sequence-stage">
            <img
              class="pu-image-scroll__sequence-img is-visible"
              data-pu-sequence-frame
              src="{{ sequence_first_url }}"
              alt=""
              width="1920"
              height="1080"
              fetchpriority="high"
              decoding="sync"
            >
            <img
              class="pu-image-scroll__sequence-img"
              data-pu-sequence-frame
              alt=""
              width="1920"
              height="1080"
              decoding="sync"
            >
          </div>
        </div>
      </div>

      <div
        class="pu-image-scroll__gallery-layer"
        data-pu-scroll-gallery
        data-gallery-set-scroll-vh="{{ gallery_set_scroll }}"
        aria-hidden="true"
      >
        <div class="pu-image-scroll__bg" aria-hidden="true">
          <div class="pu-image-scroll__bg-fill"></div>
          <img
            class="pu-image-scroll__green-arc"
            src="{{ 'pu-green-arc.png' | asset_url }}"
            alt=""
            width="1440"
            height="629"
            loading="lazy"
          >
          <div class="pu-image-scroll__texture pu-texture-overlay"></div>
        </div>

        <div class="pu-image-scroll__slots" data-pu-gallery-slots>
          {% for slot_index in (0..2) %}
            <div class="pu-image-scroll__slot" data-pu-gallery-slot="{{ slot_index }}">
              {% for block in section.blocks %}
                {% assign block_index = forloop.index0 %}
                {% assign block_slot = block_index | modulo: 3 %}
                {% assign block_set = block_index | divided_by: 3 %}
                {% if block_slot == slot_index %}
                  <article
                    class="pu-image-scroll__card"
                    data-pu-gallery-card
                    data-set="{{ block_set }}"
                    data-slot="{{ block_slot }}"
                    {{ block.shopify_attributes }}
                  >
                    <div class="pu-image-scroll__frame">
                      {% if block.settings.image != blank %}
                        {{
                          block.settings.image
                          | image_url: width: 1000
                          | image_tag: loading: 'lazy', class: 'pu-image-scroll__image', alt: block.settings.alt
                        }}
                      {% else %}
                        <img
                          class="pu-image-scroll__image"
                          src="{{ block.settings.fallback_asset | default: 'pu-scroll-img-1.png' | asset_url }}"
                          alt="{{ block.settings.alt | escape }}"
                          loading="lazy"
                          width="485"
                          height="531"
                        >
                      {% endif %}
                      {% if block.settings.overlay_text != blank %}
                        <p
                          class="pu-image-scroll__overlay pu-image-scroll__overlay--{{ block.settings.overlay_position | default: 'bottom-left' }}"
                          style="--overlay-rotate: {{ block.settings.overlay_rotation | default: 0 }}deg"
                        >
                          {{- block.settings.overlay_text -}}
                        </p>
                      {% endif %}
                    </div>
                  </article>
                {% endif %}
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% else %}
    <div class="pu-image-scroll__purple" data-pu-scroll-purple>
      <img
        class="pu-image-scroll__rays"
        src="{{ 'pu-purple-rays.png' | asset_url }}"
        alt=""
        width="1441"
        height="927"
        loading="lazy"
      >
      <div class="pu-image-scroll__texture pu-texture-overlay"></div>
      <div class="pu-image-scroll__curved-text">
        <svg viewBox="0 0 1440 400" class="pu-image-scroll__text-svg" aria-hidden="true">
          <defs>
            <path id="pu-curve-top-{{ section.id }}" d="M-200,280 Q720,40 1640,280" fill="none"/>
            <path id="pu-curve-bottom-{{ section.id }}" d="M-100,320 Q720,80 1540,320" fill="none"/>
          </defs>
          <text class="pu-image-scroll__svg-text">
            <textPath href="#pu-curve-top-{{ section.id }}" startOffset="50%" text-anchor="middle">
              {{ section.settings.curve_text_1 | default: 'Every morning' }}
            </textPath>
          </text>
          <text class="pu-image-scroll__svg-text pu-image-scroll__svg-text--lower">
            <textPath href="#pu-curve-bottom-{{ section.id }}" startOffset="50%" text-anchor="middle">
              {{ section.settings.curve_text_2 | default: 'comes with a fresh start' }}
            </textPath>
          </text>
        </svg>
      </div>
    </div>

    <div class="pu-image-scroll__orange" data-pu-scroll-orange>
      <div class="pu-image-scroll__pin" data-pu-scroll-pin>
        <div class="pu-image-scroll__bg" aria-hidden="true">
          <div class="pu-image-scroll__bg-green"></div>
          <img
            class="pu-image-scroll__green-arc"
            src="{{ 'pu-green-arc.png' | asset_url }}"
            alt=""
            width="1440"
            height="629"
            loading="lazy"
          >
          <div class="pu-image-scroll__texture pu-texture-overlay"></div>
        </div>

        <div class="pu-image-scroll__viewport">
          <div class="pu-image-scroll__track" data-pu-scroll-track>
            {% for block in section.blocks %}
              <div class="pu-image-scroll__slide" data-pu-scroll-image {{ block.shopify_attributes }}>
                <div class="pu-image-scroll__frame">
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 1000
                      | image_tag: loading: 'lazy', class: 'pu-image-scroll__image', alt: block.settings.alt
                    }}
                  {% else %}
                    <img
                      class="pu-image-scroll__image"
                      src="{{ block.settings.fallback_asset | default: 'pu-scroll-img-1.png' | asset_url }}"
                      alt="{{ block.settings.alt | escape }}"
                      loading="lazy"
                      width="485"
                      height="531"
                    >
                  {% endif %}
                  {% if block.settings.overlay_text != blank %}
                    <p
                      class="pu-image-scroll__overlay pu-image-scroll__overlay--{{ block.settings.overlay_position | default: 'bottom-left' }}"
                      style="--overlay-rotate: {{ block.settings.overlay_rotation | default: 0 }}deg"
                    >
                      {{- block.settings.overlay_text -}}
                    </p>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .pu-image-scroll {
    position: relative;
    overflow: hidden;
  }

  .pu-image-scroll img {
    max-width: none !important;
  }

  .pu-image-scroll__stage {
    position: relative;
    min-height: 100svh;
    background: #2d0f5c;
  }

  .pu-image-scroll__sequence-layer,
  .pu-image-scroll__gallery-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    min-height: 100svh;
  }

  .pu-image-scroll__sequence-layer {
    z-index: 2;
    opacity: 1;
    visibility: visible;
    background: #2d0f5c;
  }

  .pu-image-scroll__gallery-layer {
    z-index: 3;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    background: var(--pu-orange);
    overflow: hidden;
  }

  .pu-image-scroll__sequence-layer.is-active {
    opacity: 1;
    visibility: visible;
  }

  .pu-image-scroll__gallery-layer.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .pu-image-scroll__sequence-layer:not(.is-active) {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .pu-image-scroll__sequence {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 100svh;
  }

  .pu-image-scroll__sequence-stage {
    position: relative;
    width: 100%;
    min-height: 100svh;
    background: #2d0f5c;
  }

  .pu-image-scroll__sequence-img {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100svh;
    object-fit: cover;
    object-position: center bottom;
    opacity: 0;
    pointer-events: none;
  }

  .pu-image-scroll__sequence-img.is-visible {
    opacity: 1;
  }

  .pu-image-scroll__gallery-layer .pu-image-scroll__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .pu-image-scroll__gallery-layer .pu-image-scroll__bg-fill {
    position: absolute;
    inset: 0;
    background: var(--pu-orange);
    z-index: 0;
  }

  .pu-image-scroll__gallery-layer .pu-image-scroll__green-arc {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: auto;
    transform: translateY(-50%);
    z-index: 3;
  }

  .pu-image-scroll__gallery-layer .pu-image-scroll__texture {
    z-index: 4;
  }

  .pu-image-scroll__slots {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 6vh 4vw;
    box-sizing: border-box;
  }

  .pu-image-scroll__slot {
    position: relative;
    flex: 0 0 clamp(240px, 32vw, 460px);
    min-height: clamp(280px, 38vw, 531px);
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.2));
  }

  .pu-image-scroll__slot[data-pu-gallery-slot='0'] {
    transform: translateY(24px) rotate(4deg);
  }

  .pu-image-scroll__slot[data-pu-gallery-slot='1'] {
    transform: translateY(44px) rotate(-5deg);
    margin-right: -8px;
  }

  .pu-image-scroll__slot[data-pu-gallery-slot='2'] {
    transform: translateY(8px) rotate(-3deg);
  }

  .pu-image-scroll__card {
    position: absolute;
    inset: 0;
    opacity: 0;
    will-change: opacity;
  }

  .pu-image-scroll__purple {
    position: relative;
    z-index: 1;
    min-height: 800px;
    background: #4a1a8a;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .pu-image-scroll__rays {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }

  .pu-image-scroll__purple > .pu-image-scroll__texture {
    z-index: 1;
  }

  .pu-image-scroll__curved-text {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 60px 0 140px;
  }

  .pu-image-scroll__text-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .pu-image-scroll__svg-text {
    fill: var(--pu-white);
    font-family: var(--pu-font-display);
    font-size: clamp(48px, 6.5vw, 72px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .pu-image-scroll__svg-text--lower {
    font-size: clamp(44px, 5.5vw, 64px);
  }

  .pu-image-scroll__orange {
    position: relative;
    z-index: 2;
    margin-top: -120px;
    overflow: hidden;
    background: var(--pu-orange);
  }

  .pu-image-scroll__pin {
    position: relative;
    min-height: 904px;
    overflow: hidden;
  }

  .pu-image-scroll__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .pu-image-scroll__bg-green {
    position: absolute;
    left: 0;
    right: 0;
    top: 46%;
    bottom: 0;
    background: var(--pu-orange);
    z-index: 1;
  }

  .pu-image-scroll__green-arc {
    position: absolute;
    top: 46%;
    left: 0;
    width: 100%;
    height: auto;
    transform: translateY(-58%);
    z-index: 3;
  }

  .pu-image-scroll__bg .pu-image-scroll__texture {
    z-index: 4;
  }

  .pu-image-scroll__viewport {
    position: relative;
    z-index: 5;
    width: 100%;
    overflow: hidden;
    padding: 72px 0;
  }

  .pu-image-scroll__track {
    display: flex;
    gap: 8px;
    align-items: flex-end;
    padding: 0 4vw;
    will-change: transform;
  }

  .pu-image-scroll__slide {
    flex: 0 0 clamp(240px, 32vw, 460px);
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.2));
  }

  .pu-image-scroll__slide:nth-child(3n + 1) {
    transform: translateY(24px) rotate(4deg);
  }

  .pu-image-scroll__slide:nth-child(3n + 2) {
    transform: translateY(44px) rotate(-5deg);
    margin-right: -8px;
  }

  .pu-image-scroll__slide:nth-child(3n) {
    transform: translateY(8px) rotate(-3deg);
  }

  .pu-image-scroll__frame {
    position: relative;
  }

  .pu-image-scroll__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .pu-image-scroll__overlay {
    position: absolute;
    z-index: 2;
    margin: 0;
    max-width: 75%;
    font-family: 'Homemade Apple', cursive;
    font-size: clamp(22px, 2.8vw, 36px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--pu-white);
    text-shadow: 0 0 12px rgba(255, 255, 255, 0.35), 0 1px 3px rgba(0, 0, 0, 0.45);
    pointer-events: none;
    white-space: pre-line;
  }

  .pu-image-scroll__overlay--bottom-left {
    bottom: 8%;
    left: 5%;
    text-align: left;
    font-size: 28px;
    font-weight: 400;
    line-height: 118%;
    letter-spacing: -2%;
    transform: rotate(-12deg);
  }

  .pu-image-scroll__overlay--top-right {
    top: -4%;
    right: 4%;
    text-align: right;
    font-family: Homemade Apple;
    font-weight: 400;
    font-size: 28px;
    line-height: 103%;
    letter-spacing: -2%;
    transform: rotate(8deg);
  }

  .pu-image-scroll__overlay--bottom-right {
    bottom: 8%;
    right: 5%;
    transform: rotate(calc(3deg + var(--overlay-rotate, 0deg)));
    text-align: right;
  }

  .pu-image-scroll__overlay--top-left {
    top: 6%;
    left: 5%;
    transform: rotate(calc(-3deg + var(--overlay-rotate, 0deg)));
    text-align: left;
  }

  @media (max-width: 749px) {
    .pu-image-scroll__stage,
    .pu-image-scroll__sequence-layer,
    .pu-image-scroll__gallery-layer,
    .pu-image-scroll__sequence,
    .pu-image-scroll__sequence-stage,
    .pu-image-scroll__sequence-img {
      min-height: 100svh;
    }

    .pu-image-scroll__slots {
      padding: 4vh 12px;
      gap: 6px;
      overflow: hidden;
    }

    .pu-image-scroll__slot {
      flex: 1 1 0;
      min-width: 0;
      min-height: clamp(180px, 42vw, 320px);
    }

    .pu-image-scroll__slot[data-pu-gallery-slot='0'] {
      transform: translateY(12px) rotate(4deg);
    }

    .pu-image-scroll__slot[data-pu-gallery-slot='1'] {
      transform: translateY(20px) rotate(-5deg);
    }

    .pu-image-scroll__slot[data-pu-gallery-slot='2'] {
      transform: translateY(4px) rotate(-3deg);
    }

    .pu-image-scroll__gallery-layer .pu-image-scroll__green-arc {
      top: 50%;
      transform: translateY(-50%);
    }

    .pu-image-scroll__purple {
      min-height: 420px;
    }

    .pu-image-scroll__curved-text {
      padding: 32px 0 72px;
    }

    .pu-image-scroll__orange {
      margin-top: -48px;
      min-height: 100svh;
      background: transparent;
    }

    .pu-image-scroll__pin {
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .pu-image-scroll__viewport {
      padding: 24px 0;
    }

    .pu-image-scroll__track {
      padding: 0 16px;
    }

    .pu-image-scroll__slide {
      flex: 0 0 clamp(200px, 72vw, 320px);
    }

    .pu-image-scroll__slide:nth-child(3n + 1) {
      transform: translateY(12px) rotate(4deg);
    }

    .pu-image-scroll__slide:nth-child(3n + 2) {
      transform: translateY(20px) rotate(-5deg);
    }

    .pu-image-scroll__slide:nth-child(3n) {
      transform: translateY(4px) rotate(-3deg);
    }

    .pu-image-scroll__overlay--bottom-left,
    .pu-image-scroll__overlay--top-right {
      font-size: clamp(16px, 4.5vw, 22px);
    }

    .pu-image-scroll__image {
      max-width: 100% !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Image Scroll",
  "class": "pu-image-scroll-section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "image",
      "name": "Scroll image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "default": "pu-scroll-img-1.png"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        },
        {
          "type": "header",
          "content": "Handwritten overlay"
        },
        {
          "type": "textarea",
          "id": "overlay_text",
          "label": "Overlay text",
          "info": "Optional script-style caption on the image. Use line breaks for multiple lines."
        },
        {
          "type": "select",
          "id": "overlay_position",
          "label": "Text position",
          "options": [
            { "value": "bottom-left", "label": "Bottom left" },
            { "value": "top-right", "label": "Top right" },
            { "value": "bottom-right", "label": "Bottom right" },
            { "value": "top-left", "label": "Top left" }
          ],
          "default": "bottom-left"
        },
        {
          "type": "range",
          "id": "overlay_rotation",
          "label": "Extra rotation",
          "min": -20,
          "max": 20,
          "step": 1,
          "unit": "deg",
          "default": 0
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "PNG scroll sequence"
    },
    {
      "type": "select",
      "id": "sequence_storage",
      "label": "Frame file location",
      "default": "shop_files",
      "options": [
        { "value": "shop_files", "label": "Settings → Files (recommended)" },
        { "value": "theme_assets", "label": "Theme → Edit code → Assets" }
      ],
      "info": "Use Settings → Files when frames are uploaded under Content in the Shopify admin."
    },
    {
      "type": "text",
      "id": "sequence_basename",
      "label": "Sequence image basename",
      "default": "Seq_",
      "info": "Example: Seq_ for Seq_00054.png … Seq_00410.png."
    },
    {
      "type": "text",
      "id": "sequence_first_frame",
      "label": "First frame number",
      "default": "00054",
      "info": "Must match your first uploaded file (e.g. 00054 for Seq_00054.png)."
    },
    {
      "type": "number",
      "id": "sequence_frame_count",
      "label": "Total frames on CDN",
      "default": 357
    },
    {
      "type": "number",
      "id": "sequence_handoff_frame",
      "label": "Handoff frame number",
      "default": 380,
      "info": "File number where the green gallery appears (e.g. 380 for Seq_00380.png)."
    },
    {
      "type": "select",
      "id": "sequence_pad_digits",
      "label": "Frame number digits",
      "default": "5",
      "options": [
        { "value": "3", "label": "3 (001)" },
        { "value": "4", "label": "4 (0001)" },
        { "value": "5", "label": "5 (00000)" },
        { "value": "6", "label": "6 (000000)" }
      ]
    },
    {
      "type": "number",
      "id": "sequence_start_number",
      "label": "First frame index",
      "default": 54,
      "info": "Numeric value of the first file. Use 54 when files start at Seq_00054.png."
    },
    {
      "type": "range",
      "id": "sequence_scroll_vh",
      "label": "Sequence scroll length",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "vh",
      "default": 120,
      "info": "Scroll distance while playing frames up to the handoff frame."
    },
    {
      "type": "range",
      "id": "gallery_set_scroll_vh",
      "label": "Gallery set scroll length",
      "min": 30,
      "max": 120,
      "step": 5,
      "unit": "vh",
      "default": 55,
      "info": "Scroll distance for each set of 3 images to fade in."
    },
    {
      "type": "text",
      "id": "sequence_alt",
      "label": "Sequence accessibility label",
      "default": "Every morning comes with a fresh start"
    },
    {
      "type": "header",
      "content": "Static curved text fallback"
    },
    {
      "type": "paragraph",
      "content": "Shown only when no sequence basename is set."
    },
    {
      "type": "text",
      "id": "curve_text_1",
      "label": "Curved text line 1",
      "default": "Every morning"
    },
    {
      "type": "text",
      "id": "curve_text_2",
      "label": "Curved text line 2",
      "default": "comes with a fresh start"
    }
  ],
  "presets": [
    {
      "name": "PU Image Scroll",
      "blocks": [
        {
          "type": "image",
          "settings": {
            "fallback_asset": "pu-scroll-img-1.png",
            "alt": "Lifestyle",
            "overlay_text": "I have a 9 am meeting\nShould I have the 5th drink?",
            "overlay_position": "bottom-left"
          }
        },
