{% liquid
  assign content_blocks = section.blocks | where: 'type', 'scramble_text'
  assign video_blocks = section.blocks | where: 'type', 'scramble_video'
  assign has_content_blocks = false
  if content_blocks.size > 0 or video_blocks.size > 0
    assign has_content_blocks = true
  endif
%}

<section class="pu-scramble" data-pu-scramble>
  <div class="pu-scramble__inner">
    <div class="pu-scramble__text-wrap">
      <p class="pu-scramble__text" data-pu-scramble-text>
        {% if has_content_blocks %}
          {% assign scramble_prev_content = false %}
          {% assign scramble_video_index = 0 %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'scramble_text' %}
                {% if scramble_prev_content %} {% endif %}
                <span class="pu-scramble__segment" data-pu-scramble-segment {{ block.shopify_attributes }}>
                  {{- block.settings.text -}}
                </span>
                {% assign scramble_prev_content = true %}
              {% when 'scramble_patch' %}
                {% if scramble_prev_content %} {% endif %}
                {% assign patch_positioned = false %}
                {% if block.settings.position_top != blank
                  or block.settings.position_left != blank
                  or block.settings.position_bottom != blank
                  or block.settings.position_right != blank
                %}
                  {% assign patch_positioned = true %}
                {% endif %}
                <span
                  class="pu-scramble__patch{% if patch_positioned %} pu-scramble__patch--positioned{% endif %}"
                  data-pu-scramble-patch
                  style="
                    --patch-rotate: {{ block.settings.rotation | default: -6 }}deg;
                    {%- if block.settings.position_top != blank %} top: {{ block.settings.position_top }};{% endif %}
                    {%- if block.settings.position_left != blank %} left: {{ block.settings.position_left }};{% endif %}
                    {%- if block.settings.position_bottom != blank %} bottom: {{ block.settings.position_bottom }};{% endif %}
                    {%- if block.settings.position_right != blank %} right: {{ block.settings.position_right }};{% endif %}
                  "
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </span>
                {% assign scramble_prev_content = true %}
              {% when 'scramble_video' %}
                {% assign scramble_video_index = scramble_video_index | plus: 1 %}
                {% if scramble_prev_content %} {% endif %}
                <span
                  class="pu-scramble__video"
                  data-pu-scramble-video
                  data-play-delay="{{ block.settings.play_delay | default: 0 }}"
                  data-video-index="{{ scramble_video_index }}"
                  style="--video-rotate: {{ block.settings.rotation | default: 0 }}deg;"
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.video != blank %}
                    {{
                      block.settings.video
                      | video_tag:
                        image_size: '600x',
                        autoplay: false,
                        loop: false,
                        muted: true,
                        playsinline: true,
                        controls: false,
                        preload: 'auto',
                        class: 'pu-scramble__video-el'
                    }}
                  {% elsif block.settings.poster != blank %}
                    {{
                      block.settings.poster
                      | image_url: width: 600
                      | image_tag: class: 'pu-scramble__video-el', loading: 'lazy', alt: block.settings.alt
                    }}
                  {% else %}
                    <span class="pu-scramble__video-placeholder" aria-hidden="true"></span>
                  {% endif %}
                </span>
                {% assign scramble_prev_content = true %}
            {% endcase %}
          {% endfor %}
        {% else %}
          <span class="pu-scramble__segment" data-pu-scramble-segment>
            {{ section.settings.full_text }}
          </span>
        {% endif %}
      </p>
    </div>

    <div class="pu-scramble__ticker" data-pu-product-ticker>
      <div class="pu-scramble__ticker-marquee" aria-hidden="true">
        <div class="pu-scramble__ticker-track" data-pu-ticker-track>
          {% liquid
            assign ticker_blocks = section.blocks | where: 'type', 'ticker_image'
            if ticker_blocks.size == 0
              assign ticker_blocks = section.blocks | where: 'type', 'product_image'
            endif
          %}
          <div class="pu-scramble__ticker-group" data-pu-ticker-group>
            {% if ticker_blocks.size == 0 %}
              {% for i in (1..8) %}
                <img
                  src="{{ 'pu-product-mockup.png' | asset_url }}"
                  alt=""
                  class="pu-scramble__ticker-img"
                  width="37"
                  height="94"
                  loading="lazy"
                >
              {% endfor %}
            {% else %}
              {% for block in ticker_blocks %}
                {% render 'pu-scramble-ticker-item', block: block, show_editor_attrs: true %}
              {% endfor %}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-scramble {
    background: var(--pu-navy);
    min-height: 1310px;
    position: relative;
    overflow: hidden;
  }

  .pu-scramble__inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 120px 32px 200px;
    position: relative;
    z-index: 10;
  }

  .pu-scramble__text-wrap {
    position: relative;
  }

  .pu-scramble__text {
    font-family: var(--pu-font-display);
    font-size: clamp(48px, 10vw, 142px);
    font-weight: 800;
    line-height: 0.76;
    letter-spacing: -2.8px;
    text-transform: uppercase;
    color: var(--pu-gray);
    margin: 0;
    text-align: center;
    min-height: 600px;
  }

  .pu-scramble__segment {
    display: inline;
  }

  .pu-scramble__word {
    display: inline-block;
    will-change: transform, opacity;
  }

  .pu-scramble__patch {
    display: inline-block;
    vertical-align: middle;
    font-family: var(--pu-font-body);
    font-size: 42px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
    text-transform: uppercase;
    color: var(--pu-navy);
    background: #fff;
    border: 2px solid var(--pu-navy);
    border-radius: 6px;
    padding: 14px 20px;
    margin: 0 0.08em;
    transform: rotate(var(--patch-rotate));
    transform-origin: center center;
    will-change: transform, opacity;
  }

  .pu-scramble__patch--positioned {
    position: absolute;
    z-index: 5;
    margin: 0;
  }

  .pu-scramble__video {
    display: inline-block;
    vertical-align: -0.06em;
    width: 2.35em;
    height: 0.68em;
    margin: 0 0.04em;
    background: var(--pu-yellow);
    border-radius: 0.08em;
    overflow: hidden;
    /* transform: rotate(var(--video-rotate)); */
    transform-origin: center center;
    will-change: transform, opacity;
  }

  .pu-scramble__video-el,
  .pu-scramble__video-placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .pu-scramble__video-placeholder {
    background: var(--pu-yellow);
  }

  .pu-scramble__ticker {
    position: absolute;
    bottom: 60px;
    left: 50%;
    transform: translateX(-50%);
    width: min(711px, 90vw);
    height: 130px;
    background: #0064e7;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .pu-scramble__ticker-marquee {
    overflow: hidden;
    width: 100%;
  }

  .pu-scramble__ticker-track {
    display: flex;
    width: max-content;
    flex-wrap: nowrap;
    animation: pu-scramble-ticker-scroll var(--pu-scramble-ticker-duration, 24s) linear infinite;
    will-change: transform;
  }

  .pu-scramble__ticker-track.is-ready {
    animation-play-state: running;
  }

  .pu-scramble__ticker-track:not(.is-ready) {
    animation-play-state: paused;
  }

  .pu-scramble__ticker-group {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    padding: 0 10px;
  }

  @keyframes pu-scramble-ticker-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pu-scramble__ticker-track {
      animation: none;
    }
  }

  .pu-scramble__ticker-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
  }

  .pu-scramble__ticker-img {
    flex: 0 0 auto;
    height: 94px;
    width: auto !important;
    max-width: none !important;
    object-fit: contain;
  }

  @media (max-width: 749px) {
    .pu-scramble {
      min-height: auto;
    }

    .pu-scramble__inner {
      padding: 64px 16px 140px;
    }

    .pu-scramble__text {
      min-height: auto;
      font-size: clamp(28px, 16vw, 64px);
    }

    .pu-scramble__video {
      width: 2.1em;
      height: 0.62em;
    }

    .pu-scramble__patch {
      font-size: 0.34em;
      padding: 0.4em 0.7em;
    }

    .pu-scramble__ticker {
      width: calc(100% - 32px);
      height: 96px;
      bottom: 32px;
    }

    .pu-scramble__ticker-img {
      height: 64px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Scramble Text",
  "class": "pu-scramble-section",
  "blocks": [
    {
      "type": "scramble_text",
      "name": "Text",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Life isn't ALL FUN"
        }
      ]
    },
    {
      "type": "scramble_patch",
      "name": "Word patch",
      "settings": [
        {
          "type": "paragraph",
          "content": "A small rotated sticker-style word, e.g. \"LITTLE\" or \"HAVE\". Leave position fields blank to place it inline with the text; fill any of them in to pin it on top of the text instead."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "LITTLE"
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Rotation",
          "min": -20,
          "max": 20,
          "step": 1,
          "unit": "deg",
          "default": -6
        },
        {
          "type": "header",
          "content": "Position (optional)"
        },
        {
          "type": "paragraph",
          "content": "Set any combination of Top, Left, Bottom, Right (e.g. \"12%\" or \"20px\") to pin the patch to a fixed spot over the text."
        },
        {
          "type": "text",
          "id": "position_top",
          "label": "Top"
        },
        {
          "type": "text",
          "id": "position_left",
          "label": "Left"
        },
        {
          "type": "text",
          "id": "position_bottom",
          "label": "Bottom"
        },
        {
          "type": "text",
          "id": "position_right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "scramble_video",
      "name": "Video",
      "settings": [
        {
          "type": "paragraph",
          "content": "Place this block after a Text block. Text blocks below will continue after the video."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster image",
          "info": "Shown when no video is uploaded."
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Poster alt text"
        },
        {
          "type": "range",
          "id": "play_delay",
          "label": "Play delay",
          "info": "Seconds to wait before the first video plays when the section enters view. Does not delay handoffs between videos.",
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "s",
          "default": 0
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Rotation",
          "min": -20,
          "max": 20,
          "step": 1,
          "unit": "deg",
          "default": 0
        }
      ]
    },
    {
      "type": "ticker_image",
      "name": "Ticker image",
      "limit": 24,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "info": "Used when no image is uploaded. File must exist in theme assets.",
          "default": "pu-product-mockup.png"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
