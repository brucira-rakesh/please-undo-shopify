{% liquid
  assign content_blocks = section.blocks | where: 'type', 'scramble_text'
  assign video_blocks = section.blocks | where: 'type', 'scramble_video'
  assign has_content_blocks = false
  if content_blocks.size > 0 or video_blocks.size > 0
    assign has_content_blocks = true
  endif
%}

<section class="pu-scramble" data-pu-scramble>
  <div class="pu-scramble__inner">
    <div class="pu-scramble__text-wrap">
      <p class="pu-scramble__text" data-pu-scramble-text>
        {% if has_content_blocks %}
          {% assign scramble_prev_content = false %}
          {% assign scramble_video_index = 0 %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'scramble_text' %}
                {% if scramble_prev_content %} {% endif %}
                <span class="pu-scramble__segment" data-pu-scramble-segment {{ block.shopify_attributes }}>
                  {{- block.settings.text -}}
                </span>
                {% assign scramble_prev_content = true %}
              {% when 'scramble_video' %}
                {% assign scramble_video_index = scramble_video_index | plus: 1 %}
                {% if scramble_prev_content %} {% endif %}
                <span
                  class="pu-scramble__video"
                  data-pu-scramble-video
                  data-play-delay="{{ block.settings.play_delay | default: 0 }}"
                  data-video-index="{{ scramble_video_index }}"
                  style="--video-rotate: {{ block.settings.rotation | default: 0 }}deg;"
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.video != blank %}
                    {{
                      block.settings.video
                      | video_tag:
                        image_size: '600x',
                        autoplay: false,
                        loop: true,
                        muted: true,
                        playsinline: true,
                        controls: false,
                        preload: 'auto',
                        class: 'pu-scramble__video-el'
                    }}
                  {% elsif block.settings.poster != blank %}
                    {{
                      block.settings.poster
                      | image_url: width: 600
                      | image_tag: class: 'pu-scramble__video-el', loading: 'lazy', alt: block.settings.alt
                    }}
                  {% else %}
                    <span class="pu-scramble__video-placeholder" aria-hidden="true"></span>
                  {% endif %}
                </span>
                {% assign scramble_prev_content = true %}
            {% endcase %}
          {% endfor %}
        {% else %}
          <span class="pu-scramble__segment" data-pu-scramble-segment>
            {{ section.settings.full_text }}
          </span>
        {% endif %}
      </p>
    </div>

    <div class="pu-scramble__ticker" data-pu-product-ticker>
      <div class="pu-scramble__ticker-track" data-pu-ticker-track aria-hidden="true">
        {% assign ticker_images = section.blocks | where: 'type', 'product_image' %}
        {% for pass in (1..2) %}
          {% if ticker_images.size == 0 %}
            {% for i in (1..17) %}
              <img
                src="{{ 'pu-product-mockup.png' | asset_url }}"
                alt=""
                class="pu-scramble__ticker-img"
                width="37"
                height="94"
                loading="lazy"
              >
            {% endfor %}
          {% else %}
            {% for block in section.blocks %}
              {% if block.type == 'product_image' %}
                <div
                  {% if pass == 1 %}
                    {{ block.shopify_attributes -}}
                  {% endif %}
                >
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 80
                      | image_tag: class: 'pu-scramble__ticker-img', loading: 'lazy'
                    }}
                  {% else %}
                    <img
                      src="{{ 'pu-product-mockup.png' | asset_url }}"
                      alt=""
                      class="pu-scramble__ticker-img"
                      width="37"
                      height="94"
                      loading="lazy"
                    >
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pu-scramble {
    background: var(--pu-navy);
    min-height: 1310px;
    position: relative;
    overflow: hidden;
  }

  .pu-scramble__inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 120px 32px 200px;
    position: relative;
  }

  .pu-scramble__text {
    font-family: var(--pu-font-display);
    font-size: clamp(48px, 10vw, 142px);
    font-weight: 800;
    line-height: 0.76;
    letter-spacing: -2.8px;
    text-transform: uppercase;
    color: var(--pu-gray);
    margin: 0;
    text-align: center;
    min-height: 600px;
  }

  .pu-scramble__segment {
    display: inline;
  }

  .pu-scramble__word {
    display: inline-block;
    will-change: transform, opacity;
  }

  .pu-scramble__video {
    display: inline-block;
    vertical-align: -0.06em;
    width: 2.35em;
    height: 0.68em;
    margin: 0 0.04em;
    background: var(--pu-yellow);
    border-radius: 0.08em;
    overflow: hidden;
    transform: rotate(var(--video-rotate));
    transform-origin: center center;
    will-change: transform, opacity;
  }

  .pu-scramble__video-el,
  .pu-scramble__video-placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .pu-scramble__video-placeholder {
    background: var(--pu-yellow);
  }

  .pu-scramble__ticker {
    position: absolute;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%);
    width: min(711px, 90vw);
    height: 130px;
    background: #0064e7;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .pu-scramble__ticker-track {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    width: max-content;
    padding: 0 20px;
    animation: pu-scramble-ticker-scroll 24s linear infinite;
    will-change: transform;
  }

  @keyframes pu-scramble-ticker-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pu-scramble__ticker-track {
      animation: none;
    }
  }

  .pu-scramble__ticker-img {
    flex: 0 0 auto;
    height: 94px;
    width: auto !important;
    max-width: none !important;
    object-fit: contain;
  }

  @media (max-width: 749px) {
    .pu-scramble__text {
      min-height: auto;
      font-size: 36px;
    }

    .pu-scramble__video {
      width: 2.1em;
      height: 0.62em;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PU Scramble Text",
  "class": "pu-scramble-section",
  "blocks": [
    {
      "type": "scramble_text",
      "name": "Text",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Life isn't ALL FUN"
        }
      ]
    },
    {
      "type": "scramble_video",
      "name": "Video",
      "settings": [
        {
          "type": "paragraph",
          "content": "Place this block after a Text block. Text blocks below will continue after the video."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster image",
          "info": "Shown when no video is uploaded."
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Poster alt text"
        },
        {
          "type": "range",
          "id": "play_delay",
          "label": "Play delay",
          "info": "Seconds to wait before the first video plays when the section enters view. Does not delay handoffs between videos.",
          "min": 0,
          "max": 10,
          "step": 1,
          "unit": "s",
          "default": 0
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Rotation",
          "min": -20,
          "max": 20,
          "step": 1,
          "unit": "deg",
          "default": 0
        }
      ]
    },
    {
      "type": "product_image",
      "name": "Ticker product image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Add Text and Video blocks below to control where videos appear. Block order defines the reading flow."
    },
    {
      "type": "textarea",
      "id": "full_text",
      "label": "Fallback text",
      "info": "Used only when no Text or Video blocks are added.",
      "default": "Life isn't ALL FUN and frolic. It has many annoying pains. Good thing we have a HACK TO UNDO THEM."
    }
  ],
  "presets": [
    {
      "name": "PU Scramble Text",
      "blocks": [
        {
          "type": "scramble_text",
          "settings": {
            "text": "Life isn't ALL FUN"
          }
        },
        {
          "type": "scramble_video",
          "settings": {
            "rotation": -4,
            "play_delay": 0
          }
        },
        {
          "type": "scramble_text",
          "settings": {
            "text": "and frolic. It has many annoying"
          }
        },
        {
          "type": "scramble_video",
          "settings": {
            "rotation": 3,
            "play_delay": 0
          }
        },
        {
          "type": "scramble_text",
          "settings": {
            "text": "pains. Good thing we have a HACK TO UNDO THEM."
          }
        }
      ]
    }
  ]
}
{% endschema %}
